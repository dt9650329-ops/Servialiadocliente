          tiendaNombre: carritoData.tienda.nombre,
          items: carritoData.items.map(item => ({
            nombre: item.nombre,
            precio: item.precio,
            opciones: item.opciones || null
          })),
          total: carritoData.total,
          timestamp: carritoData.timestamp,
          timestampCancelacion: Date.now(),
          fecha: new Date().toISOString(),
          estado: 'cancelado',
          motivo: 'cancelado_por_usuario',
          // 👤 INFORMACIÓN DEL CLIENTE
          cliente: clienteInfo
        };
        
        // Guardar en Firebase en nodo de pedidos cancelados
        const canceladosRef = window.ref(window.db, `pedidos_cancelados/${carritoData.tienda.id}`);
        await window.push(canceladosRef, pedidoCanceladoData);
        
        console.log('✅ Pedido CANCELADO registrado en Firebase');
        
        // Actualizar estadísticas
        const estadisticasRef = window.ref(window.db, `negocios/${carritoData.tienda.id}/estadisticas`);
        const estadisticasSnapshot = await window.get(estadisticasRef);
        
        let estadisticas = {
          totalPedidosCancelados: 0
        };
        
        if (estadisticasSnapshot.exists()) {
          estadisticas = estadisticasSnapshot.val();
        }
        
        estadisticas.totalPedidosCancelados = (estadisticas.totalPedidosCancelados || 0) + 1;
        
        await window.update(estadisticasRef, estadisticas);
        
        console.log('✅ Estadísticas de cancelación actualizadas');
      }
      
    } catch (error) {
      console.error('❌ Error al registrar cancelación:', error);
    }
    
    // Limpiar carrito y cerrar modal
    carritoTienda = [];
    limpiarCarritoStorage();
    actualizarCarritoUI();
    
    const modal = document.getElementById('modal-confirmacion-pedido');
    if (modal) modal.remove();
    
    alert('🗑️ Pedido cancelado\n\nEl carrito ha sido limpiado.');
  }
  
  
  // Cerrar modales al hacer clic fuera
  window.addEventListener('click', function(event) {
    const modalProducto = document.getElementById('modal-producto-mi-tienda');
    const modalMiTienda = document.getElementById('modal-mi-tienda-productos');
    const modalVerTienda = document.getElementById('modal-ver-tienda');
    
    if (event.target === modalProducto) {
      cerrarModalProductoMiTienda();
    }
    if (event.target === modalMiTienda) {
      cerrarModalMiTienda();
    }
    if (event.target === modalVerTienda) {
      cerrarModalVerTienda();
    }
  });


</script>

