function escucharMensajesP2P(pedidoId) {
  if (_chatP2PListener) { try { _chatP2PListener(); } catch(e){} }
  const chatRef = window.ref(window.db, 'chat_p2p/' + pedidoId);
  _chatP2PListener = window.onValue(chatRef, snap => {
    const box = document.getElementById('chat-p2p-box');
    if (!box) return;
    box.innerHTML = '';
    let total = 0, noLeidos = 0;
    snap.forEach(child => {
      const m = child.val();
      total++;
      const esCliente = m.remitente === 'cliente';
      if (!esCliente && !m.leido) noLeidos++;
      const div = document.createElement('div');
      div.style.cssText = 'display:flex;flex-direction:column;align-items:' + (esCliente?'flex-end':'flex-start') + ';margin-bottom:8px;';
      let contenido = '';
      if (m.tipo === 'imagen') {
        contenido = '<img src="' + m.url + '" style="max-width:200px;border-radius:8px;cursor:pointer;" onclick="window.open(this.src)" />';
      } else if (m.tipo === 'audio') {
        contenido = '<audio controls src="' + m.url + '" style="max-width:220px;"></audio>';
      } else {
        contenido = '<span style="word-break:break-word;">' + (m.texto||'') + '</span>';
      }
      const nombreMostrar = esCliente ? '' : (m.repartidorNombre || 'Repartidor');
      div.innerHTML = '<div style="max-width:78%;background:' + (esCliente?'#1a3a5c':'#2a2a2a') + ';border-radius:12px;padding:8px 12px;color:#fff;font-size:14px;direction:ltr;">'
        + (!esCliente && nombreMostrar ? '<span style="font-size:11px;color:#4A9EFF;font-weight:bold;display:block;margin-bottom:4px;">🏍️ ' + nombreMostrar + '</span>' : '')
        + contenido
        + '<span style="font-size:10px;color:#888;display:block;margin-top:4px;text-align:right;">' + new Date(m.ts||Date.now()).toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'}) + '</span></div>';
      box.appendChild(div);
    });
    box.scrollTop = box.scrollHeight;
    // Badge mensajes no leídos
    const badge = document.getElementById('chat-rep-badge');
    if (badge) { if (noLeidos > 0) { badge.textContent = noLeidos + ' nuevo' + (noLeidos>1?'s':''); badge.style.display='inline'; } else { badge.style.display='none'; } }
    // Marcar como leídos los mensajes del repartidor
    if (noLeidos > 0) marcarLeidosP2P(pedidoId, 'repartidor');
  });
}

function marcarLeidosP2P(pedidoId, remitente) {
  const chatRef = window.ref(window.db, 'chat_p2p/' + pedidoId);
  window.get(chatRef).then(snap => {
    snap.forEach(child => {
      const m = child.val();
      if (m.remitente === remitente && !m.leido) {
        window.update(window.ref(window.db, 'chat_p2p/' + pedidoId + '/' + child.key), { leido: true });
      }
    });
  });
}

window.enviarMensajeP2P = function() {
