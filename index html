    dd.classList.remove('show');
    abrirModalSugerirBarrio(tipo, document.getElementById('search-barrio-' + tipo).value.trim());
  };
  dd.appendChild(sugerir);

  if (dentroArmenia.length || fueraArmenia.length || true) dd.classList.add('show');
};

