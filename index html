      <button type="button" class="btn-eliminar-card" onclick="eliminarCard('${categoria}', ${index})">
        🗑️ Eliminar
      </button>
    `;
    
    container.appendChild(card);
  }

  
  // Eliminar card
  window.eliminarCard = function(categoria, index) {
    if (confirm('¿Eliminar esta opción?')) {
      opcionesProducto[categoria].splice(index, 1);
      
      // Recargar todas las cards de esta categoría
      const container = document.getElementById(`cards-${categoria}`);
      container.innerHTML = '';
      
      opcionesProducto[categoria].forEach((opcion, idx) => {
        mostrarCard(categoria, opcion, idx);
      });
    }
  }

