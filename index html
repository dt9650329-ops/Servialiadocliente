    // ═══════════════════════════════════════════════════════════════════
    // 🎁 SECCIÓN PREMIOS — Día Bomba + Ruleta de Descuentos
    // ═══════════════════════════════════════════════════════════════════

    // ── Colores y premios de la ruleta ──────────────────────────────────
    // PROBABILIDADES INTERNAS (no visibles al público):
    //   25%       → 5%   de veces
    //   30%       → 10%  de veces
    //   20%       → 30%  de veces
    //   15%       → 30%  de veces  (completar hasta 100% con los demás)
    //   Domi $6k  → 10%  de veces
    //   75%       → 15%  de veces
    // Usamos pesos proporcionales (suma = 100)
    const RULETA_PREMIOS = [
        { label: '20%',            color: '#4f46e5', probabilidad: 30 },
        { label: '15%',            color: '#7c3aed', probabilidad: 25 },
        { label: '75%',            color: '#a21caf', probabilidad: 15 },
        { label: '30%',            color: '#9333ea', probabilidad: 10 },
        { label: 'Domi Gratis',    color: '#d97706', probabilidad: 10 },
        { label: '25%',            color: '#1d4ed8', probabilidad:  5 },
        { label: 'Sin Premio',     color: '#374151', probabilidad:  5 },
    ];

    // ── Estado en memoria (caché local para la sesión) ──────────────────
    let _premiosCache = null;

    // ── Semana ISO (YYYY-WNN) para resetear contador semanal ────────────
    function _semanaActual() {
        const d = new Date();
        const jan1 = new Date(d.getFullYear(), 0, 1);
        const week = Math.ceil(((d - jan1) / 86400000 + jan1.getDay() + 1) / 7);
        return `${d.getFullYear()}-W${String(week).padStart(2,'0')}`;
    }

    // ── Ruta Firebase del perfil de premios del usuario ─────────────────
    function _premiosFirebasePath() {
        const uid = window.currentUserID;
        if (!uid) return null;
        return `usuarios/${uid}/premios`;
    }

    // ── Leer estado desde Firebase (async) ─────────────────────────────
    async function _premiosGetEstadoFirebase() {
        const path = _premiosFirebasePath();
        if (!path || !window.db || !window.ref || !window.get) {
            // Sin Firebase: usar caché en memoria
            return _premiosCache || { pedidosAcum: 0, girosDisp: 0, serviciosSemana: 0, semanaISO: '' };
        }
        try {
            const snap = await window.get(window.ref(window.db, path));
            const data = snap.exists() ? snap.val() : { pedidosAcum: 0, girosDisp: 0, serviciosSemana: 0, semanaISO: '' };
            _premiosCache = data;
            return data;
        } catch(e) {
            console.warn('⚠️ Error leyendo premios Firebase:', e);
            return _premiosCache || { pedidosAcum: 0, girosDisp: 0, serviciosSemana: 0, semanaISO: '' };
        }
    }

    // ── Leer estado (sync desde caché, para funciones que no pueden ser async) ──
    function _premiosGetEstado() {
        return _premiosCache || { pedidosAcum: 0, girosDisp: 0, serviciosSemana: 0, semanaISO: '' };
    }

    // ── Guardar estado en Firebase + actualizar caché ───────────────────
    async function _premiosSetEstado(est) {
        _premiosCache = est;
        const path = _premiosFirebasePath();
        if (!path || !window.db || !window.ref || !window.update) return;
        try {
            await window.update(window.ref(window.db, path), est);
        } catch(e) {
            console.warn('⚠️ Error guardando premios Firebase:', e);
        }
    }

    // ── Cargar estado al iniciar sesión ─────────────────────────────────
    window.cargarPremiosDesdeFirebase = async function() {
        await _premiosGetEstadoFirebase();

        // 🔄 SINCRONIZACIÓN INICIAL: si el usuario nunca ha sincronizado su historial,
        // se cuenta cuántos pedidos completados tiene y se inicializa pedidosAcum.
        // El flag `historialSincronizado` evita que corra de nuevo en cada login.
        if (!_premiosCache.historialSincronizado && window.currentUserID && window.db && window.ref && window.get) {
            try {
                const histSnap = await window.get(window.ref(window.db, 'pedidos_historial'));
                let conteo = 0;
                if (histSnap.exists()) {
                    histSnap.forEach(child => {
                        const p = child.val();
                        if (p.clienteIdAsignado === window.currentUserID &&
                            ['completado','entregado'].includes((p.estado || '').toLowerCase())) {
                            conteo++;
                        }
                    });
                }
                // Sincronizar: si el historial tiene más pedidos que el XP actual, usar el historial
                const pedidosActuales = _premiosCache.pedidosAcum || 0;
                if (conteo > pedidosActuales) {
                    _premiosCache.pedidosAcum = conteo;
                    // Giros históricos: 1 cada 3 pedidos (solo si no había giros previos)
                    if ((_premiosCache.girosDisp || 0) === 0) {
                        _premiosCache.girosDisp = Math.floor(conteo / 3);
                    }
                    console.log(`🔄 XP sincronizado desde historial: ${conteo} pedidos completados`);
                }
                // Marcar como sincronizado para no volver a correr
                _premiosCache.historialSincronizado = true;
                await _premiosSetEstado(_premiosCache);
                console.log('✅ Flag historialSincronizado guardado en Firebase');
            } catch(e) {
                console.warn('⚠️ Error sincronizando XP desde historial:', e);
            }
        }

        window.initPremiosUI();
        window.actualizarNivelPerfil();
        console.log('✅ Premios/XP cargados desde Firebase:', _premiosCache);
    };

    // ── Inicializar pantalla de Premios ─────────────────────────────────
    window.initPremiosUI = function() {
        const est = _premiosGetEstado();
        const semanaHoy = _semanaActual();

        // Resetear contador semanal si cambió la semana (async, no bloquea UI)
        if (est.semanaISO !== semanaHoy) {
            est.serviciosSemana = 0;
            est.semanaISO = semanaHoy;
            _premiosSetEstado(est);
        }

        // ── DÍA BOMBA ──
        const hoy = new Date().getDay();
        const horaActual = new Date().getHours() * 60 + new Date().getMinutes(); // minutos desde medianoche
        // Franjas bomba: 8-11am, 2-6pm, 8-10pm
        const enFranja = (horaActual >= 480 && horaActual < 660)   // 08:00-11:00
                      || (horaActual >= 840 && horaActual < 1080)  // 14:00-18:00
                      || (horaActual >= 1200 && horaActual < 1320);// 20:00-22:00
        const esDiaBomba = (hoy === 2) && enFranja; // solo martes
        const servicios  = est.serviciosSemana || 0;
        const desbloqueado = servicios >= 80;
        window._clienteDiaBombaActivo = esDiaBomba && desbloqueado;

        const elBloq  = document.getElementById('bomba-bloqueado');
        const elDesbloq = document.getElementById('bomba-desbloqueado');
        if (elBloq && elDesbloq) {
            if (desbloqueado) {
                elBloq.style.display    = 'none';
                elDesbloq.style.display = 'block';
            } else {
                elBloq.style.display    = 'block';
                elDesbloq.style.display = 'none';
                const pct = Math.min(100, Math.round((servicios/80)*100));
                const fill = document.getElementById('bomba-progreso-fill');
                const txt  = document.getElementById('bomba-progreso-texto');
                if (fill) fill.style.width = pct + '%';
                if (txt)  txt.textContent  = `${servicios} / 80 servicios esta semana`;
            }
        }

        // ── RULETA ──
        const giros = est.girosDisp || 0;
        const pedAcum = est.pedidosAcum || 0;
        const pedParaGiro = 3 - (pedAcum % 3 || (pedAcum > 0 && pedAcum % 3 === 0 ? 3 : 0));
        const pctRuleta = Math.round(((pedAcum % 3) / 3) * 100);

        const cntGiros  = document.getElementById('ruleta-giros-count');
        const progFill  = document.getElementById('ruleta-prog-fill');
        const progTxt   = document.getElementById('ruleta-prog-texto');
        if (cntGiros) cntGiros.textContent = giros;
        if (progFill) progFill.style.width = pctRuleta + '%';
        if (progTxt)  progTxt.textContent  = `${pedAcum % 3} / 3 pedidos para el próximo giro`;

        const btnGirar = document.getElementById('btn-girar-ruleta');
        if (btnGirar) {
            btnGirar.disabled = giros <= 0;
            btnGirar.style.opacity = giros > 0 ? '1' : '0.45';
            btnGirar.textContent = giros > 0 ? '🎰 ¡Girar Ruleta!' : '🔒 Sin giros disponibles';
        }

        // Dibujar ruleta
        _dibujarRuleta(0);
        _actualizarBonosUI();
    };

    // ── Dibujar ruleta en canvas ─────────────────────────────────────────
    // NOTA: Los sectores se dibujan con TAMAÑO VISUAL IGUAL (360°/n cada uno)
    // Las probabilidades internas siguen siendo las de RULETA_PREMIOS.probabilidad
    function _dibujarRuleta(anguloOffset) {
        const canvas = document.getElementById('ruleta-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const cx = 130, cy = 130, r = 122;
        const n = RULETA_PREMIOS.length;
        const sliceEqual = (2 * Math.PI) / n;   // todos los sectores iguales visualmente
        let startAngle = anguloOffset;

        ctx.clearRect(0, 0, 260, 260);

        // Sombra exterior
        ctx.save();
        ctx.shadowColor = 'rgba(99,102,241,0.5)';
        ctx.shadowBlur = 18;
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, 2 * Math.PI);
        ctx.fillStyle = '#1e1b4b';
        ctx.fill();
        ctx.restore();

        RULETA_PREMIOS.forEach((premio, i) => {
            const slice = sliceEqual;
            // Sector con gradiente
            const grad = ctx.createRadialGradient(cx, cy, r*0.2, cx, cy, r);
            grad.addColorStop(0, _lightenColor(premio.color, 40));
            grad.addColorStop(1, premio.color);

            ctx.beginPath();
            ctx.moveTo(cx, cy);
            ctx.arc(cx, cy, r, startAngle, startAngle + slice);
            ctx.closePath();
            ctx.fillStyle = grad;
            ctx.fill();
            ctx.strokeStyle = '#08080f';
            ctx.lineWidth = 2.5;
            ctx.stroke();

            // Texto del premio
            ctx.save();
            ctx.translate(cx, cy);
            ctx.rotate(startAngle + slice / 2);
            ctx.textAlign = 'right';
            ctx.fillStyle = '#ffffff';
            ctx.shadowColor = 'rgba(0,0,0,0.8)';
            ctx.shadowBlur = 4;
            ctx.font = 'bold 14px sans-serif';
            ctx.fillText(premio.label, r - 12, 5);
            ctx.restore();

            startAngle += slice;
        });

        // Aro exterior decorativo
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, 2 * Math.PI);
        ctx.strokeStyle = 'rgba(167,139,250,0.5)';
        ctx.lineWidth = 3;
        ctx.stroke();

        // Centro hub
        const hubGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, 20);
        hubGrad.addColorStop(0, '#6366f1');
        hubGrad.addColorStop(1, '#1e1b4b');
        ctx.beginPath();
        ctx.arc(cx, cy, 20, 0, 2 * Math.PI);
        ctx.fillStyle = hubGrad;
        ctx.fill();
        ctx.strokeStyle = '#a78bfa';
        ctx.lineWidth = 2;
        ctx.stroke();

        // Estrella en el centro
        ctx.fillStyle = '#fbbf24';
        ctx.font = 'bold 16px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('★', cx, cy);
    }

    function _lightenColor(hex, amount) {
        const num = parseInt(hex.replace('#',''), 16);
        const r = Math.min(255, (num >> 16) + amount);
        const g = Math.min(255, ((num >> 8) & 0xFF) + amount);
        const b = Math.min(255, (num & 0xFF) + amount);
        return `rgb(${r},${g},${b})`;
    }

    // ── Animación y lógica de giro ───────────────────────────────────────
    window.girarRuleta = function() {
        const est = _premiosGetEstado();
        if ((est.girosDisp || 0) <= 0) {
            alert('No tienes giros disponibles. Completa 3 pedidos para ganar uno.');
            return;
        }

        const btnGirar = document.getElementById('btn-girar-ruleta');
        if (btnGirar) btnGirar.disabled = true;

        // Elegir premio según probabilidad
        const total = RULETA_PREMIOS.reduce((s,p) => s + p.probabilidad, 0);
        let rand = Math.random() * total;
        let premioGanado = RULETA_PREMIOS[0];
        let acum = 0;
        for (const p of RULETA_PREMIOS) {
            acum += p.probabilidad;
            if (rand <= acum) { premioGanado = p; break; }
        }

        // Calcular ángulo final — sectores visuales IGUALES (360°/n)
        const n = RULETA_PREMIOS.length;
        const sliceEqual = (2 * Math.PI) / n;
        const idxGanado = RULETA_PREMIOS.indexOf(premioGanado);
        const angInicio = idxGanado * sliceEqual;
        const angPremio = angInicio + sliceEqual / 2;
        const targetAngle = (2 * Math.PI * 5) + ((3 * Math.PI / 2) - angPremio);

        // Animar
        let current = 0;
        const duration = 3000;
        const start = performance.now();
        function step(now) {
            const elapsed = now - start;
            const t = Math.min(elapsed / duration, 1);
            const ease = 1 - Math.pow(1 - t, 3);
            current = targetAngle * ease;
            _dibujarRuleta(current);
            if (t < 1) {
                requestAnimationFrame(step);
            } else {
                // Giro terminado — descontar giro y guardar en Firebase
                est.girosDisp = Math.max(0, (est.girosDisp || 1) - 1);
                _premiosSetEstado(est); // async, guarda en Firebase

                const esSinPremio = premioGanado.label === 'Sin Premio';
                const codigoBase  = premioGanado.label === 'Domi Gratis'
                    ? 'DOMI' : premioGanado.label.replace('%','').replace(/\s/g,'');
                const codigo = esSinPremio ? '' : 'SA-' + codigoBase + '-' + Math.random().toString(36).substr(2,5).toUpperCase();
                const resDiv = document.getElementById('ruleta-resultado');
                const resTxt = document.getElementById('ruleta-resultado-texto');
                const resCod = document.getElementById('ruleta-cupon-codigo');
                if (resDiv && resTxt && resCod) {
                    resTxt.textContent = premioGanado.label === 'Domi Gratis'
                        ? '🎉 ¡Ganaste un Domicilio Gratis! (máx $6.000 · el excedente lo asumes tú)'
                        : esSinPremio
                        ? '😕 Sin suerte esta vez... ¡Sigue intentando!'
                        : `🎊 ¡Ganaste ${premioGanado.label} de descuento!`;
                    resCod.textContent = codigo ? `Código: ${codigo} · Muéstraselo al admin` : '';
                    resCod.style.display = codigo ? 'inline-block' : 'none';
                    resDiv.style.display = 'block';
                }
                // Guardar bono en lista acumulada
                if (!esSinPremio) _guardarBonoGanado(premioGanado.label, codigo);
                _actualizarBonosUI();
                window.initPremiosUI();
            }
        }
        requestAnimationFrame(step);
    };

    // ── Llamar initPremiosUI cuando se entre al tab de Premios ──────────
    // (se integra en changeTab más abajo)

    // ── Actualizar panel de bonos acumulados ────────────────────────────
