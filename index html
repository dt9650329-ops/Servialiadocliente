    function sanitizarHTML(texto) {
      if (texto === null || texto === undefined) return '';
      const div = document.createElement('div');
      div.appendChild(document.createTextNode(String(texto)));
      return div.innerHTML;
    }
    
    // Llamada segura al backend con token de Firebase
    async function llamarBackend(endpoint, method = 'GET', body = null) {
      const auth = window.firebaseAuth;
      if (!auth || !auth.currentUser) throw new Error('No autenticado');
      
      const token = await auth.currentUser.getIdToken();
      const opciones = {
        method,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        }
      };
      if (body) opciones.body = JSON.stringify(body);
      
      const response = await fetch(`${BACKEND_URL}${endpoint}`, opciones);
      const data = await response.json();
      
      if (!response.ok) throw new Error(data.error || 'Error del servidor');
      return data;
    }
    window.llamarBackend = llamarBackend;

