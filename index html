function cargarBarriosDesdeFirebase() {
  if (!window.db) { setTimeout(cargarBarriosDesdeFirebase, 800); return; }
  try {
    const barriosRef = window.ref(window.db, 'barrios');
    window.onValue(barriosRef, snap => {
