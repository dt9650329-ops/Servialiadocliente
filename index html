    let isRecordingAdmin = false;
    let mediaRecorderAdmin = null;
    let audioChunksAdmin = [];

    window.toggleGrabarAudioAdmin = async function() {
        if (isRecordingAdmin) {
            detenerGrabacionAdmin();
        } else {
            await iniciarGrabacionAdmin();
        }
    }

    async function iniciarGrabacionAdmin() {
        try {
            console.log('🎙️ Iniciando grabación de audio para admin...');
            
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            mediaRecorderAdmin = new MediaRecorder(stream);
            audioChunksAdmin = [];

            mediaRecorderAdmin.ondataavailable = (event) => {
                if (event.data.size > 0) {
                    audioChunksAdmin.push(event.data);
                }
            };

            mediaRecorderAdmin.onstop = async () => {
                console.log('🎙️ Grabación detenida, procesando audio...');
                const audioBlob = new Blob(audioChunksAdmin, { type: 'audio/webm' });
                await enviarAudioAdmin(audioBlob);
                
                stream.getTracks().forEach(track => track.stop());
            };

            mediaRecorderAdmin.start();
            isRecordingAdmin = true;

            const btnAudio = document.getElementById('admin-btn-audio');
            const statusElement = document.getElementById('admin-audio-recording-status');
            
            btnAudio.textContent = '⏹️ Detener';
            btnAudio.style.backgroundColor = '#ff4444';
            statusElement.style.display = 'block';
            statusElement.textContent = '🔴 Grabando audio...';

            console.log('✅ Grabación iniciada');
        } catch (error) {
            console.error('❌ Error al iniciar grabación:', error);
            alert('Error al acceder al micrófono: ' + error.message);
        }
    }

    function detenerGrabacionAdmin() {
        if (mediaRecorderAdmin && mediaRecorderAdmin.state !== 'inactive') {
            mediaRecorderAdmin.stop();
            isRecordingAdmin = false;

            const btnAudio = document.getElementById('admin-btn-audio');
            const statusElement = document.getElementById('admin-audio-recording-status');
            
            btnAudio.textContent = '🎙️ Grabar Audio';
            btnAudio.style.backgroundColor = '';
            statusElement.style.display = 'none';

            console.log('✅ Grabación detenida');
        }
    }

