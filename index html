  input.value = '';
};

window.toggleGrabarAudioP2P = async function() {
  const btn = document.getElementById('btn-audio-p2p');
  if (!_chatP2PRecording) {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      _chatP2PAudio = new MediaRecorder(stream);
      _chatP2PAudioChunks = [];
      _chatP2PAudio.ondataavailable = e => _chatP2PAudioChunks.push(e.data);
      _chatP2PAudio.onstop = () => {
        const blob = new Blob(_chatP2PAudioChunks, { type: 'audio/webm' });
        const url = URL.createObjectURL(blob);
        document.getElementById('preview-audio-p2p').src = url;
        document.getElementById('audio-preview-p2p').style.display = 'block';
        _chatP2PAudio._blob = blob;
        stream.getTracks().forEach(t => t.stop());
      };
      _chatP2PAudio.start();
      _chatP2PRecording = true;
      btn.textContent = '⏹️ Detener';
      btn.style.background = '#c0392b';
    } catch(e) { alert('Error al acceder al micrófono'); }
  } else {
    _chatP2PAudio.stop();
    _chatP2PRecording = false;
    btn.textContent = '🎤 Audio';
    btn.style.background = '#333';
  }
};

window.enviarAudioP2P = async function() {
  if (!_chatP2PAudio || !_chatP2PAudio._blob || !_chatP2PId) return;
  try {
    const { ref: sRef, uploadBytes, getDownloadURL } = await import('https://www.gstatic.com/firebasejs/10.12.2/firebase-storage.js');
    const storRef = sRef(window.storage, 'chat_p2p/' + _chatP2PId + '/audio_' + Date.now() + '.webm');
    const snap = await uploadBytes(storRef, _chatP2PAudio._blob);
    const url = await getDownloadURL(snap.ref);
    const msgRef = window.push(window.ref(window.db, 'chat_p2p/' + _chatP2PId));
    window.set(msgRef, { tipo:'audio', url, remitente:'cliente', ts: Date.now(), leido: false });
    cancelarAudioP2P();
  } catch(e) { alert('Error al subir audio: ' + e.message); }
};

window.cancelarAudioP2P = function() {
  document.getElementById('audio-preview-p2p').style.display = 'none';
  document.getElementById('preview-audio-p2p').src = '';
  if (_chatP2PAudio) _chatP2PAudio._blob = null;
};
</script>


