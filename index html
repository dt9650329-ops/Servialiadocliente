    function crearTarjetaNegocio(negocioId, negocio, esMiTienda) {
        const card = document.createElement('div');
        
        // Determinar clase según estado
        let estadoClase = '';
        let badgeHTML = '';
        
        if (esMiTienda) {
            const estado = negocio.estado || 'pendiente';
            estadoClase = estado;
            
            let badgeText = '';
            let badgeClass = '';
            
            switch(estado) {
                case 'aprobado':  // ✅ Corregido: era 'aprobada'
                case 'aprobada':  // Mantener compatibilidad
                    badgeText = 'Aprobada';
                    badgeClass = 'approved';
                    break;
                case 'rechazado':  // ✅ Corregido: era 'rechazada'
                case 'rechazada':  // Mantener compatibilidad
                    badgeText = 'Rechazada';
                    badgeClass = 'rejected';
                    break;
                default:
                    badgeText = 'Pendiente';
                    badgeClass = 'pending';
            }
            
            badgeHTML = `
                <span class="store-status-badge ${badgeClass}">${badgeText}</span>
                <span class="my-store-indicator">MI TIENDA</span>
            `;
        }
        
        card.className = `store-card ${estadoClase}`;
        
        const imagenHTML = negocio.imagen ? 
            `<img src="${negocio.imagen}" alt="${negocio.nombre}" />` : 
            '🏪';
        
        // Botón de editar para MI TIENDA
        const botonEditar = esMiTienda ? 
            `<button class="btn-editar-mi-tienda" onclick="event.stopPropagation(); abrirModalEditarMiTienda('${negocioId}')">
                ✏️ Editar Mi Tienda
            </button>` : '';
        
        card.innerHTML = `
            ${badgeHTML}
            <div class="store-image" onclick="${esMiTienda ? `abrirModalEditarMiTienda('${negocioId}')` : `verProductosTienda('${negocioId}', '${negocio.nombre.replace(/'/g, "\\'")}')`}">${imagenHTML}</div>
            <div class="store-info">
                <div class="store-name">${negocio.nombre}</div>
                <div class="store-description">${negocio.descripcion}</div>
                <div class="store-meta">
                    <span class="store-category">${negocio.categoria}</span>
                    <span class="store-phone">📞 ${negocio.telefono}</span>
                </div>
                ${botonEditar}
            </div>
        `;
        
        return card;
    }

