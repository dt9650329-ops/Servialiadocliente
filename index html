                                // ═══════════════════════════════════════════════════════════
                                // Verificar si la recogida del nuevo pedido está cerca de la ruta
                                const distRecogidaAEntrega = calcularDistancia(
                                    nuevoPedido.coordsRecogida,
                                    { lat: rGPS.lat, lng: rGPS.lng } // Simulamos destino con GPS del repartidor
                                );
                                
                                if (distRecogidaAEntrega < 2000) { // Menos de 2km = "en ruta"
