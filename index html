                                // 🎯 REGLA 4: Zonas DIFERENTES y NO en ruta
                                //            → ENTREGAR primero el pedido actual, luego recoger el nuevo
                                // ═══════════════════════════════════════════════════════════
                                console.log('⏳ Debe completar entrega actual en zona diferente primero');
                                // Tiempo de entregar el pedido actual + volver
                                const tiempoEntrega = 8; // ~8 min promedio entregar
                                const tiempoRegreso = Math.ceil(distRepartidorARecogida / velocidadMs / 60);
                                tiempoAdicional += tiempoEntrega + Math.ceil(tiempoRegreso * 0.5); // 50% del regreso
                                if (!explicacionRuta) {
                                    explicacionRuta = `⏳ Completará entrega en ${pedido.zonaEntrega || 'otra zona'} primero`;
