  // Guardar carrito en localStorage
  function guardarCarritoEnStorage() {
    try {
      if (tiendaActual && carritoTienda.length > 0) {
        const carritoData = {
          tienda: tiendaActual,
          items: carritoTienda,
          timestamp: Date.now()
        };
