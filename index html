  async function cargarProductosMiTienda(negocioId) {
    const listaProductos = document.getElementById('lista-productos-mi-tienda');
    
    try {
      // Obtener la categoría del negocio para determinar qué rutas leer
      const negocioSnapshot = await get(ref(db, 'negocios/' + negocioId));
      let categoriaNegocio = 'general';
      
      if (negocioSnapshot.exists()) {
        const negocioData = negocioSnapshot.val();
        categoriaNegocio = negocioData.categoria ? negocioData.categoria.toLowerCase() : 'general';
      }
      
      console.log('📋 Cargando productos - Categoría:', categoriaNegocio);
      
      listaProductos.innerHTML = '';
      
      let todosLosProductos = {};
      
      // Para restaurantes, leer de múltiples nodos
      if (categoriaNegocio === 'restaurante' || categoriaNegocio === 'restaurantes') {
        console.log('🍽️ Es restaurante, leyendo menús...');
        
        // Leer desayunos
        try {
          const desayunosSnapshot = await get(ref(db, `negocios/${negocioId}/menu/desayunos`));
          if (desayunosSnapshot.exists()) {
            const desayunos = desayunosSnapshot.val();
            for (let id in desayunos) {
              todosLosProductos[id] = { ...desayunos[id], _rutaOrigen: 'menu/desayunos' };
            }
            console.log('✅ Desayunos cargados:', Object.keys(desayunos).length);
          }
        } catch (error) {
          console.log('⚠️ No hay desayunos:', error.message);
        }
        
        // Leer almuerzos
        try {
          const almuerzosSnapshot = await get(ref(db, `negocios/${negocioId}/menu/almuerzos`));
          if (almuerzosSnapshot.exists()) {
            const almuerzos = almuerzosSnapshot.val();
            for (let id in almuerzos) {
              todosLosProductos[id] = { ...almuerzos[id], _rutaOrigen: 'menu/almuerzos' };
            }
            console.log('✅ Almuerzos cargados:', Object.keys(almuerzos).length);
          }
        } catch (error) {
          console.log('⚠️ No hay almuerzos:', error.message);
        }
        
        // Leer otros (si existen)
        try {
          const otrosSnapshot = await get(ref(db, `negocios/${negocioId}/menu/otros`));
          if (otrosSnapshot.exists()) {
            const otros = otrosSnapshot.val();
            for (let id in otros) {
              todosLosProductos[id] = { ...otros[id], _rutaOrigen: 'menu/otros' };
            }
            console.log('✅ Otros cargados:', Object.keys(otros).length);
          }
        } catch (error) {
          console.log('⚠️ No hay otros menús:', error.message);
        }
      } else {
        // Para otros tipos de negocios, leer de /productos
        console.log('🏪 Leyendo productos generales...');
        const productosSnapshot = await get(ref(db, 'negocios/' + negocioId + '/productos'));
        
        if (productosSnapshot.exists()) {
          todosLosProductos = productosSnapshot.val();
          console.log('✅ Productos cargados:', Object.keys(todosLosProductos).length);
        }
      }
      
      // Si no hay productos
      if (Object.keys(todosLosProductos).length === 0) {
        listaProductos.innerHTML = '<p class="no-products-message">No tienes productos aún. ¡Agrega tu primer producto!</p>';
        return;
      }
      
      // Renderizar productos
      for (let productoId in todosLosProductos) {
        const producto = todosLosProductos[productoId];
        const disponible = producto.disponible !== false;
        
        const productoDiv = document.createElement('div');
        productoDiv.className = 'product-item-edit';
        
        const precioHTML = producto.precio ? `<div style="color: var(--color-primary); font-size: 14px;">$${parseInt(producto.precio).toLocaleString('es-ES')}</div>` : '';
        
        // Mostrar tipo de menú si existe
        let tipoMenuHTML = '';
        if (producto.tipoMenu) {
          const emoji = producto.tipoMenu === 'desayuno' ? '🌅' : producto.tipoMenu === 'almuerzo' ? '🍽️' : '🍴';
          tipoMenuHTML = `<div style="color: #999; font-size: 12px; margin-top: 5px;">${emoji} ${producto.tipoMenu.charAt(0).toUpperCase() + producto.tipoMenu.slice(1)}</div>`;
        }
        
        // Generar galería de imágenes si existen
        let imagenesHTML = '';
        if (producto.imagenes && producto.imagenes.length > 0) {
          imagenesHTML = '<div class="product-images-gallery">';
          producto.imagenes.forEach((url, index) => {
            imagenesHTML += `<img src="${url}" alt="${producto.nombre} ${index + 1}" onclick="window.open('${url}', '_blank')">`;
          });
          imagenesHTML += '</div>';
        }
        
        // Determinar la ruta completa para las operaciones
        let rutaProducto = producto._rutaOrigen || 'productos';
        
        productoDiv.innerHTML = `
          <div class="product-info-edit">
            <div class="product-name-edit">${producto.nombre}</div>
            ${precioHTML}
            ${tipoMenuHTML}
            ${imagenesHTML}
            <div class="product-status-edit ${disponible ? 'disponible' : 'no-disponible'}">
              ${disponible ? '✅ Disponible' : '❌ No disponible'}
            </div>
          </div>
          <div class="product-actions-edit">
            <button class="btn-toggle-disponibilidad ${disponible ? 'disponible' : 'no-disponible'}" 
                    onclick="toggleDisponibilidadProducto('${negocioId}', '${productoId}', ${!disponible}, '${rutaProducto}')">
              ${disponible ? 'Marcar No Disponible' : 'Marcar Disponible'}
            </button>
            <button class="btn-eliminar-producto" onclick="eliminarProductoMiTienda('${negocioId}', '${productoId}', '${producto.nombre}', '${rutaProducto}')">
              🗑️
            </button>
          </div>
        `;
        
        listaProductos.appendChild(productoDiv);
      }
      
    } catch (error) {
      console.error('Error al cargar productos:', error);
      listaProductos.innerHTML = '<p class="no-products-message">Error al cargar productos</p>';
    }
  }
  
