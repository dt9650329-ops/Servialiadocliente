        const card       = document.getElementById('perfil-nivel-card');

        if (badge)     { badge.textContent = nivelActual.emoji; badge.style.background = `linear-gradient(135deg,${nivelActual.color},${nivelSig.color})`; }
        if (nombre)    nombre.textContent = nivelActual.nombre;
        if (numEl)     numEl.textContent  = `Nivel ${nivelActual.nivel} · ${totalPedidos} domicilio${totalPedidos !== 1 ? 's' : ''}`;
        if (sigEl)     sigEl.textContent  = esMaxNivel ? '¡Nivel máximo!' : nivelSig.nombre;
        if (faltaEl)   faltaEl.textContent= esMaxNivel ? '🏆 Completado' : `${faltantes} más para subir`;
        if (fill)      fill.style.width   = pct + '%';
        if (xpLabel)   xpLabel.textContent= esMaxNivel ? '¡Nivel máximo!' : `${pedEnNivel} / ${rangNivel} XP`;
        if (beneficios)beneficios.innerHTML = nivelActual.beneficios.split('\n').map(b => `<div>${b}</div>`).join('');
        if (card)      card.style.borderColor = `${nivelActual.color}66`;
    };

    // Actualizar nivel al cargar el tab de perfil
    const _origChangeTab = window.changeTab;
    if (!window._nivelHookInstalado) {
        window._nivelHookInstalado = true;
        const _nivelOrig = window.changeTab;
        // Piggybacking en el evento del tab
        document.addEventListener('DOMContentLoaded', async () => {
            if (window.currentUserID) await window.cargarPremiosDesdeFirebase();
            window.actualizarNivelPerfil();
        });
        // Carga diferida por si Firebase aún no está listo al cargar la página
        setTimeout(async () => {
            if (window.currentUserID) await window.cargarPremiosDesdeFirebase();
            window.actualizarNivelPerfil();
        }, 1500);
    }

