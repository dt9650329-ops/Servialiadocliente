// Ubicación del cliente — solo se activa cuando hay sesión iniciada
window._iniciarUbicacionCliente = function() {
  if (!navigator.geolocation || window._ubicClienteActivo) return;
  window._ubicClienteActivo = true;
  navigator.geolocation.watchPosition(pos => {
    if (!window.currentUserID || !window.db || !window.set || !window.ref) return;
    const { latitude: lat, longitude: lng, accuracy } = pos.coords;
    try {
      window.set(window.ref(window.db, 'ubicaciones_clientes/' + window.currentUserID), {
        lat: parseFloat(lat.toFixed(6)),
        lng: parseFloat(lng.toFixed(6)),
        accuracy: Math.round(accuracy),
        ts: Date.now()
      }).catch(() => {});
    } catch(e) {}
  }, null, { enableHighAccuracy: true, maximumAge: 30000, timeout: 15000 });
};

