    // Calcular y mostrar tiempo real del repartidor en el formulario
    async function _actualizarTiempoEstimadoFormulario() {
        const elRecogida = document.getElementById('domi-tiempo-recogida-texto');
        const elEntrega  = document.getElementById('domi-tiempo-entrega-texto');
        const elExplicacion = document.getElementById('domi-explicacion-ruta');
        if (!elRecogida || !elEntrega) return;

        try {
            const repsSnap = await window.get(window.ref(window.db, 'repartidores_info'));
            if (!repsSnap.exists()) {
                elRecogida.textContent = '15 – 25 minutos';
                elEntrega.textContent  = '30 – 45 minutos';
                if (elExplicacion) {
                    elExplicacion.style.display = 'none';
                }
                return;
            }

            let repartidorDisponible = null;
            repsSnap.forEach(child => {
                const d = child.val();
                if (d.online === true && (d.pedidosActivos || 0) < 2 && !repartidorDisponible) {
                    repartidorDisponible = { uid: child.key, ...d };
                }
            });

            if (!repartidorDisponible) {
                elRecogida.textContent = '15 – 25 minutos';
                elEntrega.textContent  = '30 – 45 minutos';
                if (elExplicacion) {
                    elExplicacion.textContent = 'ℹ️ No hay repartidores disponibles en este momento';
                    elExplicacion.style.display = 'block';
                }
                return;
            }

            const rGPS = repartidorDisponible.ubicacionActual || repartidorDisponible.ubicacion;
            const pedidosEnCola = repartidorDisponible.pedidosActivos || 0;
            const zonaRecogida = document.getElementById('domi-zona-recogida').value;
            const zonaEntrega  = document.getElementById('domi-zona-entrega').value;

            if (rGPS && rGPS.lat && (rGPS.lng || rGPS.lon)) {
                let tiempoBase = 5; // Tiempo base estimado
                let tiempoAdicional = 0;
                let explicacion = '';

                // 🔍 Si tiene pedidos activos, obtener detalles para calcular mejor
                if (pedidosEnCola > 0) {
                    try {
                        const pedidosRef = window.ref(window.db, `repartidores_pedidos/${repartidorDisponible.uid}`);
                        const pedidosSnap = await window.get(pedidosRef);
                        
                        if (pedidosSnap.exists()) {
                            const pedidos = Object.values(pedidosSnap.val()).filter(p => 
                                p.estado === 'aceptado' || p.estado === 'en_camino' || p.estado === 'pendiente'
                            );

                            const tiempoActual = Date.now();
                            let hayUrgentes = false;
                            let enMismaZona = false;

                            for (const pedido of pedidos) {
                                const tiempoConPedido = (tiempoActual - (pedido.timestamp || tiempoActual)) / 60000;
                                
                                // REGLA 1: Pedidos urgentes (>20 min)
                                if (tiempoConPedido > 20) {
                                    hayUrgentes = true;
                                    tiempoAdicional += 10; // Debe entregar primero
                                }
                                // REGLA 2: Misma zona de recogida
                                else if (pedido.zonaRecogida === zonaRecogida) {
                                    enMismaZona = true;
                                    tiempoAdicional += 3; // Solo tiempo de recogida adicional
                                }
                                // REGLA 3: Zonas diferentes
                                else {
                                    tiempoAdicional += 8; // Debe completar entrega primero
                                }
                            }

                            // Generar explicación
                            if (hayUrgentes) {
                                explicacion = `⏳ El repartidor completará ${pedidos.length} entrega(s) urgente(s) primero`;
                            } else if (enMismaZona) {
                                explicacion = `✅ Recogerá tu pedido junto con otro de la misma zona`;
                            } else if (pedidos.length > 0) {
                                explicacion = `⏳ Completará entrega actual primero (zona diferente)`;
                            }

                        } else {
                            // Si no hay datos detallados, usar estimación simple
                            tiempoAdicional = pedidosEnCola * 8;
                            explicacion = `⏳ ${pedidosEnCola} pedido(s) activo(s)`;
                        }
                    } catch (err) {
                        console.warn('Error al obtener detalles de pedidos:', err);
                        tiempoAdicional = pedidosEnCola * 8;
                        explicacion = `⏳ ${pedidosEnCola} pedido(s) en cola`;
                    }
                } else {
                    // Sin pedidos activos
                    explicacion = '✅ Repartidor disponible, irá directo';
                }

                const minMin = Math.max(1, tiempoBase + tiempoAdicional);
                const minMax = minMin + 5;

                elRecogida.textContent = `${minMin} – ${minMax} minutos`;
                elEntrega.textContent = `${minMin + 10} – ${minMax + 15} minutos`;
                
                if (elExplicacion && explicacion) {
                    elExplicacion.textContent = explicacion;
                    elExplicacion.style.display = 'block';
                } else if (elExplicacion) {
                    elExplicacion.style.display = 'none';
                }

            } else {
                elRecogida.textContent = '10 – 20 minutos';
                elEntrega.textContent  = '25 – 40 minutos';
                if (elExplicacion) {
                    elExplicacion.style.display = 'none';
                }
            }
        } catch(e) {
            console.warn('Error al actualizar tiempo estimado:', e);
            // silently fail - keep default text
        }
    }

