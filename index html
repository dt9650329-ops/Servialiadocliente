  window.cerrarYGuardarMenu = async function() {
    console.log('🔄 Cerrando y guardando menú...');
    
    const titulo = document.getElementById('titulo-producto').value.trim();
    const tipoMenu = document.getElementById('tipo-menu-select').value;
    const precio = document.getElementById('precio-menu').value;
    
    // Validaciones
    if (!titulo) {
      alert('Por favor ingresa el título del menú');
      return;
    }
    
    if (!tipoMenu) {
      alert('Por favor selecciona el tipo de menú (Desayuno o Almuerzo)');
      return;
    }
    
    if (!precio || precio <= 0) {
      alert('Por favor ingresa un precio válido');
      return;
    }
    
    // Verificar que haya al menos UNA opción agregada
    const totalOpciones = Object.values(opcionesProducto).reduce((sum, arr) => sum + arr.length, 0);
    if (totalOpciones === 0) {
      alert('Por favor agrega al menos una opción (caldo, principio, acompañante o bebida)');
      return;
    }
    
    // Filtrar solo las categorías que tienen opciones
    const opcionesFiltradas = {};
    for (let cat in opcionesProducto) {
      if (opcionesProducto[cat].length > 0) {
        opcionesFiltradas[cat] = opcionesProducto[cat];
      }
    }
    
    try {
      // Determinar la ruta según el tipo de negocio y menú
      let rutaFirebase = '';
      let categoriaNegocio = 'general';
      
      const negocioSnapshot = await window.get(window.ref(window.db, 'negocios/' + miTiendaIdActual));
      if (negocioSnapshot.exists()) {
        const negocioData = negocioSnapshot.val();
        categoriaNegocio = negocioData.categoria ? negocioData.categoria.toLowerCase() : 'general';
      }
      
      if (categoriaNegocio === 'restaurante' || categoriaNegocio === 'restaurantes') {
        if (tipoMenu === 'desayuno') {
          rutaFirebase = `negocios/${miTiendaIdActual}/menu/desayunos`;
        } else if (tipoMenu === 'almuerzo') {
          rutaFirebase = `negocios/${miTiendaIdActual}/menu/almuerzos`;
        } else {
          rutaFirebase = `negocios/${miTiendaIdActual}/menu/otros`;
        }
      } else {
        rutaFirebase = `negocios/${miTiendaIdActual}/productos`;
      }
      
      const nuevoProducto = {
        nombre: titulo,
        precio: parseFloat(precio),
        tipoMenu: tipoMenu,
        esMenuPersonalizable: true,
        opciones: opcionesFiltradas,
        disponible: true,
        estado: 'aprobado',
        fechaCreacion: Date.now(),
        categoria: categoriaNegocio
      };
      
      console.log('💾 Guardando en:', rutaFirebase);
      const dbRef = window.ref(window.db, rutaFirebase);
      const resultado = await window.push(dbRef, nuevoProducto);
      console.log('✅ Guardado exitosamente!', resultado.key);
      
      // Cerrar modal
      cerrarModalProductoMiTienda();
      
      // Mensaje de éxito
      setTimeout(() => {
        alert(`✅ ¡MENÚ GUARDADO!

${nuevoProducto.nombre}
Precio: $${parseInt(precio).toLocaleString('es-ES')}
Opciones: ${totalOpciones}

Tu menú ya está visible para los clientes.`);
      }, 300);
      
      // Recargar productos
      await cargarProductosMiTienda(miTiendaIdActual);
      
    } catch (error) {
      console.error('❌ Error al guardar:', error);
      alert('Error al guardar el menú: ' + error.message);
