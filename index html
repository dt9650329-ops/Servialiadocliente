        border-radius: 6px;
        background: var(--accent-dim);
        color: var(--color-primary);
        font-weight: bold;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .menu-item-btn:hover {
