    async function _cargarBarriosFirebaseCliente() {
        if (_barriosFirebaseCacheCliente) return _barriosFirebaseCacheCliente;
        if (_barriosFirebaseCargandoCliente) {
            await new Promise(res => {
                const check = setInterval(() => {
                    if (!_barriosFirebaseCargandoCliente) { clearInterval(check); res(); }
                }, 100);
            });
            return _barriosFirebaseCacheCliente || {};
        }
        _barriosFirebaseCargandoCliente = true;
        try {
            const snap = await get(ref(db, 'barrios'));
            const resultado = {};
            if (snap.exists()) {
                snap.forEach(child => {
                    const d = child.val();
                    let lat = null, lng = null;
                    if (d.lat && (d.lng || d.lon)) {
                        lat = parseFloat(d.lat); lng = parseFloat(d.lng || d.lon);
                    } else if (d.coordenadas) {
                        lat = parseFloat(d.coordenadas.lat); lng = parseFloat(d.coordenadas.lng || d.coordenadas.lon);
                    } else if (d.ubicacion) {
                        lat = parseFloat(d.ubicacion.lat); lng = parseFloat(d.ubicacion.lng || d.ubicacion.lon);
                    }
                    if (lat && lng && !isNaN(lat) && !isNaN(lng)) {
                        const norm = s => s.toLowerCase().trim().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
                        const nombre = norm(d.nombre || child.key || '');
                        resultado[nombre] = { lat, lng };
                        const keyNorm = norm(child.key);
                        if (keyNorm !== nombre) resultado[keyNorm] = { lat, lng };
                    }
                });
                console.log('[GEO-CLIENT] 🔥 Barrios Firebase:', Object.keys(resultado).length);
            }
            _barriosFirebaseCacheCliente = resultado;
        } catch(e) {
            console.warn('[GEO-CLIENT] Error Firebase /barrios:', e);
            _barriosFirebaseCacheCliente = {};
        }
        _barriosFirebaseCargandoCliente = false;
        return _barriosFirebaseCacheCliente;
    }

    // Pre-cargar barrios al iniciar
    setTimeout(() => _cargarBarriosFirebaseCliente(), 2500);

    // Geocodifica un barrio: Firebase → diccionario local → Nominatim
    async function _geocodificarBarrioCliente(nombreBarrio) {
        if (!nombreBarrio) return null;
        const norm = s => s.toLowerCase().trim().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        const clave = norm(nombreBarrio);

        // Estrategia 1: Firebase
        try {
            const barriosDB = await _cargarBarriosFirebaseCliente();
            for (const [key, coords] of Object.entries(barriosDB)) {
                if (clave === key || clave.includes(key) || key.includes(clave)) {
                    console.log('[GEO-CLIENT] 🔥 Firebase:', key);
                    return coords;
                }
            }
        } catch(e) { console.warn('[GEO-CLIENT] Error Firebase:', e); }

        // Estrategia 2: Diccionario local
        for (const [key, coords] of Object.entries(BARRIOS_ARMENIA_CLIENT)) {
            const keyN = norm(key);
            if (clave === keyN || clave.includes(keyN) || keyN.includes(clave)) {
                console.log('[GEO-CLIENT] Diccionario local:', key);
                return coords;
            }
        }

        // Estrategia 3: Nominatim
        const variantes = [
            nombreBarrio + ', Armenia, Quindio, Colombia',
            nombreBarrio.replace(/urbanizaci[oó]n|conjunto residencial|etapa \d+| ii| i$/gi, '').trim() + ', Armenia, Colombia',
            nombreBarrio + ', Armenia, Colombia',
        ];
        for (const q of variantes) {
            try {
                const url = 'https://nominatim.openstreetmap.org/search?format=json&limit=1&countrycodes=co&q=' + encodeURIComponent(q);
                const r = await fetch(url, { headers: { 'Accept-Language': 'es' } });
                const d = await r.json();
                if (d && d.length > 0) {
                    console.log('[GEO-CLIENT] Nominatim OK:', q);
                    return { lat: parseFloat(d[0].lat), lng: parseFloat(d[0].lon) };
                }
            } catch(e) { console.warn('[GEO-CLIENT] Nominatim error:', e); }
            await new Promise(res => setTimeout(res, 350));
        }
        console.warn('[GEO-CLIENT] No encontrado:', nombreBarrio);
        return null;
    }

