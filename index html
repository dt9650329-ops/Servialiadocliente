      if (carritoTienda.length === 0) {
        carritoItems.innerHTML = '<p style="color: #999; text-align: center; padding: 20px;">Tu carrito está vacío</p>';
      } else {
        let total = 0;
        
        carritoTienda.forEach((item, index) => {
          const itemDiv = document.createElement('div');
          itemDiv.className = 'carrito-item';
          
          let opcionesHTML = '';
          if (item.opciones) {
