let _sugerirTipo = null;

window.abrirModalSugerirBarrio = function(tipo, nombreSugerido) {
  _sugerirTipo = tipo;
  document.getElementById('sugerir-nombre').value = nombreSugerido || '';
  document.getElementById('sugerir-tipo-lugar').value = 'fuera';
  document.getElementById('msg-sugerir').style.display = 'none';
  document.getElementById('modal-sugerir-barrio').style.display = 'block';
};

window.cerrarModalSugerirBarrio = function() {
  document.getElementById('modal-sugerir-barrio').style.display = 'none';
};

window.enviarSugerenciaBarrio = async function() {
  const nombre = document.getElementById('sugerir-nombre').value.trim();
  const tipoLugar = document.getElementById('sugerir-tipo-lugar').value;
  const msg = document.getElementById('msg-sugerir');

  if (!nombre) {
    msg.textContent = '⚠️ Ingresa el nombre del lugar.';
    msg.style.color = '#e74c3c';
    msg.style.display = 'block';
    return;
  }

  msg.textContent = '📍 Obteniendo tu ubicación...';
  msg.style.color = '#FFC300';
  msg.style.display = 'block';

  let lat = null, lng = null;
  try {
    const pos = await new Promise((res, rej) =>
      navigator.geolocation.getCurrentPosition(res, rej, {enableHighAccuracy:true, timeout:8000})
    );
    lat = parseFloat(pos.coords.latitude.toFixed(6));
    lng = parseFloat(pos.coords.longitude.toFixed(6));
  } catch(e) {
    msg.textContent = '⚠️ No se pudo obtener ubicación GPS. Se enviará sin coordenadas.';
    msg.style.color = '#e67e22';
  }

  try {
    msg.textContent = '⏳ Enviando sugerencia...';
    const id = 'sug_' + Date.now();
    await window.set(window.ref(window.db, 'barrios_sugeridos/' + id), {
      nombre,
      tipo:         tipoLugar,
      zona:         tipoLugar === 'fuera' ? 'fuera' : 'centro',
      lat,
      lng,
      clienteId:    window.currentUserID || 'anonimo',
      clienteNombre:window.currentUserNombre || 'Cliente',
      ts:           Date.now(),
      estado:       'pendiente'
    });

    msg.textContent = '✅ ¡Sugerencia enviada! El admin la revisará pronto.';
    msg.style.color = '#27ae60';

    // Permitir usar el lugar ya seleccionado mientras se aprueba
    if (_sugerirTipo) {
      seleccionarBarrio(_sugerirTipo, {
        n: nombre,
        z: tipoLugar === 'fuera' ? 'fuera' : 'centro',
        c: tipoLugar === 'fuera' ? 'Fuera de Armenia' : ''
      });
    }

    setTimeout(() => cerrarModalSugerirBarrio(), 2000);
  } catch(e) {
    msg.textContent = '❌ Error: ' + e.message;
    msg.style.color = '#e74c3c';
  }
};

document.getElementById('modal-sugerir-barrio')?.addEventListener('click', e => {
  if (e.target === document.getElementById('modal-sugerir-barrio')) cerrarModalSugerirBarrio();
});
</script>

