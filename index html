  // Guardar opción
  // Guardar opción - CORREGIDO PARA USAR FIREBASE STORAGE
  window.guardarOpcion = async function(categoria) {
    console.log('=== GUARDAR OPCIÓN ===');
    console.log('Categoría:', categoria);
    
    const nombreInput = document.getElementById(`nombre-${categoria}`);
    const imagenInput = document.getElementById(`imagen-${categoria}`);
    
    if (!nombreInput || !imagenInput) {
      console.error('ERROR: No se encontraron los inputs para:', categoria);
      alert('Error: No se encontraron los campos del formulario');
      return;
    }
    
    const nombre = nombreInput.value.trim();
    const imagenFile = imagenInput.files[0];
    
    console.log('Nombre:', nombre);
    console.log('Archivo:', imagenFile);
    
    if (!nombre) {
      alert('Por favor ingresa un nombre');
      return;
    }
    
    if (!imagenFile) {
      alert('Por favor selecciona una imagen');
      return;
    }
    
    try {
      // Mostrar indicador de carga en el botón
      const btnGuardar = event.target;
      const textoOriginal = btnGuardar.innerHTML;
      btnGuardar.innerHTML = '⏳ Subiendo...';
      btnGuardar.disabled = true;
      
      // SUBIR IMAGEN A FIREBASE STORAGE
      console.log('📤 Subiendo imagen a Firebase Storage...');
      const timestamp = Date.now();
      const fileName = `${timestamp}_${imagenFile.name}`;
      const imageRef = window.storageRef(window.storage, `productos/${window.currentUserID}/${fileName}`);
      
      // Subir el archivo usando uploadBytesResumable
      const uploadTask = window.uploadBytesResumable(imageRef, imagenFile);
      
      // Esperar a que termine la subida
      await new Promise((resolve, reject) => {
        uploadTask.on('state_changed',
          (snapshot) => {
            const progress = (snapshot.bytesTransferred / snapshot.totalBytes) * 100;
            console.log('Progreso:', progress + '%');
          },
          (error) => {
            console.error('Error al subir:', error);
            reject(error);
          },
          async () => {
            console.log('✅ Imagen subida exitosamente');
            resolve();
          }
        );
      });
      
      // Obtener la URL de descarga
      const imagenUrl = await window.getDownloadURL(imageRef);
      console.log('✅ URL obtenida:', imagenUrl);
      
      // Crear objeto de opción con imagenUrl (NO imagen base64)
      const opcion = {
        nombre: nombre,
        imagenUrl: imagenUrl  // ← ESTO ES CRÍTICO
      };
      
      console.log('Opción creada:', opcion);
      
      // Agregar a la lista
      opcionesProducto[categoria].push(opcion);
      console.log('Opciones actualizadas:', opcionesProducto);
      
      // Mostrar la card
      const index = opcionesProducto[categoria].length - 1;
      mostrarCard(categoria, opcion, index);
      
      // Restaurar botón
      btnGuardar.innerHTML = textoOriginal;
      btnGuardar.disabled = false;
      
      // Limpiar formulario
      cancelarOpcion(categoria);
      
      // Mostrar confirmación visual más sutil (sin alert)
      const form = document.getElementById(`form-${categoria}`);
      const confirmacion = document.createElement('div');
      confirmacion.style.cssText = 'color: #28a745; font-weight: bold; padding: 10px; text-align: center; background: rgba(40, 167, 69, 0.1); border-radius: 8px; margin-top: 10px;';
      confirmacion.textContent = `✅ ${nombre} agregado`;
      form.parentElement.insertBefore(confirmacion, form);
      
      setTimeout(() => confirmacion.remove(), 3000);
      
    } catch (error) {
      console.error('❌ Error al guardar opción:', error);
      console.error('Stack:', error.stack);
      alert('Error al guardar: ' + error.message);
      
      // Restaurar botón en caso de error
      const btnGuardar = event.target;
      if (btnGuardar) {
        btnGuardar.innerHTML = '✅ Guardar';
        btnGuardar.disabled = false;
      }
    }
  }

  
  // Mostrar card - CORREGIDO: usar imagenUrl
  function mostrarCard(categoria, opcion, index) {
    const container = document.getElementById(`cards-${categoria}`);
    
    if (!container) {
      console.error('ERROR: No se encontró el contenedor para:', categoria);
