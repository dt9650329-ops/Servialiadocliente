window.filtrarBarriosInput = function(tipo) {
  const q = document.getElementById('search-barrio-' + tipo).value.toLowerCase().trim();
  const dd = document.getElementById('dropdown-' + tipo);
  dd.innerHTML = '';
  if (q.length < 2) { dd.classList.remove('show'); return; }

  // Barrios dentro de Armenia
  const dentroArmenia = BARRIOS_ARMENIA.filter(b =>
    b.n.toLowerCase().includes(q) && b.z !== 'fuera'
  ).slice(0, 10);

  // Barrios fuera de Armenia ya registrados
  const fueraArmenia = BARRIOS_ARMENIA.filter(b =>
    b.n.toLowerCase().includes(q) && b.z === 'fuera'
  ).slice(0, 4);

  // Resultados dentro
  if (dentroArmenia.length) {
    dentroArmenia.forEach(b => {
      const d = document.createElement('div');
      d.className = 'barrio-option';
      d.innerHTML = b.n + '<span class="barrio-comuna">' + b.z.charAt(0).toUpperCase()+b.z.slice(1) + '</span>';
      d.onclick = () => seleccionarBarrio(tipo, b);
      dd.appendChild(d);
    });
  }

  // Separador + resultados fuera de Armenia
  if (fueraArmenia.length) {
    const sep = document.createElement('div');
    sep.style.cssText = 'padding:5px 12px;font-size:10px;color:#e67e22;background:#1a1200;font-weight:bold;letter-spacing:1px;border-top:1px solid #333;';
    sep.textContent = '📍 FUERA DEL PERÍMETRO DE ARMENIA';
    dd.appendChild(sep);
    fueraArmenia.forEach(b => {
      const d = document.createElement('div');
      d.className = 'barrio-option';
      d.style.cssText = 'border-left:3px solid #e67e22;';
      d.innerHTML = '🌄 ' + b.n + '<span class="barrio-comuna" style="color:#e67e22;">Fuera de Armenia</span>';
      d.onclick = () => seleccionarBarrio(tipo, {...b, z:'fuera'});
      dd.appendChild(d);
    });
  }

  // Opción sugerir siempre al final
  const sugerir = document.createElement('div');
  sugerir.className = 'barrio-option';
  sugerir.style.cssText = 'border-top:1px solid #333;color:#FFC300;font-style:italic;';
