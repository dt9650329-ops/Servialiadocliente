        }

        // ── FUERA DE ARMENIA ─────────────────────────────────
        if (/calarca|circasia|montenegro|tebaida|salento|quimbaya|filandia|buenavista|pijao|genova|cordoba|puerto tapao|fuera de armenia|otro municipio/.test(m)) {
            return `🌍 **Entregas fuera de Armenia:**\n\nSí hacemos domicilios a municipios cercanos:\n\nCalarcá, Circasia, Montenegro, La Tebaida, Puerto Tapao, Salento, Quimbaya, Filandia, Buenavista, Pijao, Génova, Córdoba y vías principales.\n\n💵 **Tarifa:** mínimo $5.000 + $1.000 por kilómetro recorrido.\nEjemplo: 4 km = $5.000 base + $4.000 km = **$9.000 total**.\n\nUn administrador te confirma el valor exacto según tu dirección.`;
        }

