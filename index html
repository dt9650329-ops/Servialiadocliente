            for (let negocioId in negocios) {
                const negocio = negocios[negocioId];
                const esMiTienda = negocio.propietario === window.currentUserID;
                
                // Mostrar si es aprobada O es la tienda propia del cliente
                if (negocio.estado === 'aprobado' || negocio.estado === 'aprobada' || esMiTienda) {
