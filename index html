        // 🔥 CALCULAR DISTANCIA PARA VERIFICAR SI SON DIFERENTES
        const distance = calcularDistancia(
            clienteCoords.lat, clienteCoords.lng,
            repartidorCoords.lat, repartidorCoords.lng
        );
        
        console.log(`📏 Distancia entre puntos: ${distance.toFixed(2)} metros`);
        
        // ✅ SI LA DISTANCIA ES MUY PEQUEÑA (< 10 metros), NO TRAZAR RUTA
        if (distance < 10) {
            console.warn('⚠️ Distancia demasiado pequeña, no se trazará ruta');
            document.getElementById('map-distance').textContent = '📏 Distancia: Muy cerca';
            document.getElementById('map-duration').textContent = '⏱️ Llegada inminente';
