  // Cargar carrito desde localStorage
  function cargarCarritoDesdeStorage() {
    try {
      const carritoGuardado = localStorage.getItem('carritoActual');
      if (carritoGuardado) {
        const carritoData = JSON.parse(carritoGuardado);
        
        // Verificar que no haya expirado (24 horas)
        const tiempoTranscurrido = Date.now() - carritoData.timestamp;
        const EXPIRACION = 24 * 60 * 60 * 1000; // 24 horas
        
        if (tiempoTranscurrido < EXPIRACION) {
          console.log('📦 Cargando carrito guardado:', carritoData);
          return carritoData;
        } else {
          console.log('⏰ Carrito expirado, eliminando...');
          localStorage.removeItem('carritoActual');
        }
      }
    } catch (error) {
      console.error('Error al cargar carrito:', error);
    }
    return null;
  }
  
  // Limpiar carrito guardado
  function limpiarCarritoStorage() {
    try {
