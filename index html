    async function cargarCatalogoProductos(negocioId) {
        const catalogoGrid = document.getElementById('catalogo-productos-tienda');
        
        try {
            const productosSnapshot = await get(ref(db, 'negocios/' + negocioId + '/productos'));
            
            catalogoGrid.innerHTML = '';
            
            if (!productosSnapshot.exists()) {
                catalogoGrid.innerHTML = '<p class="no-products-message">Esta tienda aún no tiene productos disponibles.</p>';
                return;
            }
            
            const productos = productosSnapshot.val();
            let hayProductos = false;
            
            for (let productoId in productos) {
                const producto = productos[productoId];
                const disponible = producto.disponible !== false;
                
                // Solo mostrar productos disponibles
                if (!disponible) continue;
                
                hayProductos = true;
                
                const productCard = document.createElement('div');
                productCard.className = 'product-catalog-card';
                
                // Primera imagen o emoji por defecto
                let imagenHTML = '🍽️';
                if (producto.imagenes && producto.imagenes.length > 0) {
                    imagenHTML = `<img src="${producto.imagenes[0]}" alt="${producto.nombre}">`;
                }
                
                const precioHTML = producto.precio ? 
                    `<div class="product-catalog-price">$${parseInt(producto.precio).toLocaleString('es-ES')}</div>` : '';
                
                const descripcionHTML = producto.descripcion ? 
                    `<div class="product-catalog-description">${producto.descripcion}</div>` : '';
                
                // Galería de imágenes miniatura
                let galeriaHTML = '';
                if (producto.imagenes && producto.imagenes.length > 1) {
                    galeriaHTML = '<div class="product-images-gallery">';
                    producto.imagenes.slice(1, 3).forEach((url, index) => {
                        galeriaHTML += `<img src="${url}" alt="${producto.nombre} ${index + 2}" onclick="window.open('${url}', '_blank')">`;
                    });
                    galeriaHTML += '</div>';
                }
                
                productCard.innerHTML = `
                    <div class="product-catalog-image">${imagenHTML}</div>
                    <div class="product-catalog-info">
                        <div class="product-catalog-name">${producto.nombre}</div>
                        ${descripcionHTML}
                        ${precioHTML}
                        ${galeriaHTML}
                    </div>
                `;
                
                catalogoGrid.appendChild(productCard);
            }
            
            if (!hayProductos) {
                catalogoGrid.innerHTML = '<p class="no-products-message">No hay productos disponibles en este momento.</p>';
            }
            
        } catch (error) {
            console.error('Error al cargar catálogo:', error);
            catalogoGrid.innerHTML = '<p class="no-products-message">Error al cargar los productos.</p>';
        }
    }
    
