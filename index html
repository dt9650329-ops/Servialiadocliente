                                console.log(`📦 Pedidos activos del repartidor: ${pedidosActivosRepartidor.length}`, pedidosActivosRepartidor);
                            } catch(err) {
                                console.warn('⚠️ Error al obtener pedidos del repartidor:', err);
                            }
                        }

                        // ────────────────────────────────────────────────────────────
                        // 📏 FUNCIÓN: Calcular distancia Haversine (en metros)
                        // ────────────────────────────────────────────────────────────
                        const calcularDistancia = (coords1, coords2) => {
                            if (!coords1 || !coords2 || !coords1.lat || !coords2.lat) return 999999;
                            const R = 6371e3; // Radio de la Tierra en metros
                            const lat1 = coords1.lat * Math.PI / 180;
                            const lat2 = coords2.lat * Math.PI / 180;
                            const dLat = (coords2.lat - coords1.lat) * Math.PI / 180;
                            const dLng = (coords2.lng - coords1.lng) * Math.PI / 180;
                            const a = Math.sin(dLat/2)**2 + Math.cos(lat1)*Math.cos(lat2)*Math.sin(dLng/2)**2;
                            return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
                        };

                        // ────────────────────────────────────────────────────────────
                        // ⏱️ PASO 2: Aplicar lógica de enrutamiento inteligente
                        // ────────────────────────────────────────────────────────────
                        const velocidadMs = 25000 / 3600; // 25 km/h en m/s
                        const tiempoActual = Date.now();
                        let tiempoAdicional = 0;

                        // Distancia base: repartidor -> recogida del nuevo pedido
                        const distRepartidorARecogida = calcularDistancia(rGPS, cGPS);
                        let tiempoBase = Math.ceil(distRepartidorARecogida / velocidadMs / 60); // minutos

                        if (pedidosActivosRepartidor.length > 0) {
                            console.log('🚦 ANALIZANDO RUTA ÓPTIMA...');
                            
                            for (const pedido of pedidosActivosRepartidor) {
                                // ¿Cuánto tiempo lleva el repartidor con este pedido?
                                const tiempoConPedido = (tiempoActual - (pedido.timestamp || tiempoActual)) / 60000; // minutos
                                const esUrgente = tiempoConPedido > 20; // Más de 20 min es urgente
                                
                                console.log(`📦 Pedido existente: ${pedido.zonaRecogida || '?'} → ${pedido.zonaEntrega || '?'} (${tiempoConPedido.toFixed(0)} min esperando)`);
                                
                                // ═══════════════════════════════════════════════════════════
                                // 🎯 REGLA 1: Si el pedido existente lleva mucho tiempo (>20 min)
                                //            → ENTREGAR PRIMERO antes de recoger el nuevo
                                // ═══════════════════════════════════════════════════════════
                                if (esUrgente && pedido.estado === 'aceptado') {
                                    console.log('⚠️ URGENTE: Pedido lleva más de 20 min, debe entregar primero');
                                    // Estimar: ir a entrega actual + volver a zona de recogida
                                    const distEntrega = 3000; // Estimado 3km entrega
                                    tiempoAdicional += Math.ceil(distEntrega / velocidadMs / 60) + 5; // +5 min por entrega
                                    explicacionRuta = `⚠️ El repartidor debe entregar primero un pedido urgente (${tiempoConPedido.toFixed(0)} min en cola)`;
