    window.confirmarCancelacionPedido = async function(pedidoId) {
        const motivo = document.getElementById('motivo-cancelacion').value.trim();
        
        if (!motivo) {
            alert('⚠️ Por favor escribe el motivo de la cancelación');
            return;
        }

        try {
            console.log('🚫 Cancelando pedido:', pedidoId);
            
            // 1️⃣ Obtener información del pedido
            const pedidoRef = window.ref(window.db, `pedidos_historial/${pedidoId}`);
            const pedidoSnapshot = await window.get(pedidoRef);
            
            if (!pedidoSnapshot.exists()) {
                alert('❌ Error: No se encontró el pedido');
                return;
            }
            
            const pedido = pedidoSnapshot.val();
            
            // 2️⃣ Actualizar estado del pedido a "cancelado"
            await window.update(pedidoRef, {
                estado: 'cancelado',
                motivoCancelacion: motivo,
                canceladoPor: 'cliente',
                timestampCancelacion: Date.now()
            });
            
            // 3️⃣ Si hay repartidor asignado, decrementar sus pedidos activos
            if (pedido.repartidorUID) {
                const repartidorRef = window.ref(window.db, `repartidores_info/${pedido.repartidorUID}`);
                const repartidorSnap = await window.get(repartidorRef);
                
                if (repartidorSnap.exists()) {
                    const repartidor = repartidorSnap.val();
                    const pedidosActivos = Math.max(0, (repartidor.pedidosActivos || 1) - 1);
                    await window.update(repartidorRef, { pedidosActivos });
                }
                
                // Eliminar de repartidores_pedidos
                const repPedidoRef = window.ref(window.db, `repartidores_pedidos/${pedido.repartidorUID}/${pedidoId}`);
                await window.remove(repPedidoRef);
            }
            
            // 4️⃣ Eliminar de pedidos_pendientes si existe
            const pendienteRef = window.ref(window.db, `pedidos_pendientes/${pedidoId}`);
            await window.remove(pendienteRef);
            
            // 5️⃣ Registrar en pedidos_cancelados
            const canceladosRef = window.ref(window.db, 'pedidos_cancelados');
            await window.push(canceladosRef, {
                ...pedido,
                id: pedidoId,
                motivoCancelacion: motivo,
                canceladoPor: 'cliente',
                timestampCancelacion: Date.now()
            });
            
            console.log('✅ Pedido cancelado exitosamente');
            
            // 6️⃣ Cerrar modal de cancelación
            cerrarModalCancelar();
            
            // 7️⃣ Enviar mensaje automático al admin con el motivo
            const chatRef = window.ref(window.db, `soporte_cliente/${window.currentUserID}`);
            const nuevoMensajeRef = window.push(chatRef);
            
            const mensajeAdmin = `🚫 PEDIDO CANCELADO

ID: #${pedidoId.substring(0, 8)}
Descripción: ${pedido.descripcion || 'N/A'}
Monto: $${(pedido.montoTotal || 0).toLocaleString('es-ES')}

Motivo de cancelación:
${motivo}`;
            
            await window.set(nuevoMensajeRef, {
                mensaje: mensajeAdmin,
                remitente: 'cliente',
                timestamp: Date.now(),
                leido: false,
                clienteNombre: window.currentUserNombre || 'Cliente',
                clienteEmail: window.currentUserEmail || '',
                tipoPedido: 'cancelacion',
                pedidoId: pedidoId
            });
            
            // 8️⃣ Abrir chat con admin automáticamente
            document.getElementById('modal-chat-admin').style.display = 'block';
            cargarMensajesAdmin();
            
            // Auto-scroll al final
            setTimeout(() => {
                const container = document.getElementById('chat-messages-container');
                if (container) {
                    container.scrollTop = container.scrollHeight;
                }
            }, 100);
            
            // 9️⃣ Mostrar confirmación
            alert('✅ Pedido cancelado exitosamente.\n\nSe ha abierto el chat con soporte para que puedas recibir más información si lo necesitas.');
            
            // 🔟 Recargar vista de pedidos
            verMisPedidos();
            
        } catch (error) {
            console.error('❌ Error al cancelar pedido:', error);
            alert('❌ Error al cancelar el pedido. Por favor intenta de nuevo o contacta a soporte.');
        }
    }
    
