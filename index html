        console.log('📤 Subiendo audio al chat con admin...');
        const statusElement = document.getElementById('admin-audio-recording-status');
        statusElement.style.display = 'block';
        statusElement.textContent = '📤 Enviando audio...';

        try {
            const timestamp = Date.now();
            const fileName = `admin_audio_${window.currentUserID}_${timestamp}.webm`;
            const fileRef = window.storageRef(window.storage, `chats_admin/${fileName}`);
            
            const uploadTask = window.uploadBytesResumable(fileRef, audioBlob);

            uploadTask.on('state_changed',
                (snapshot) => {
                    const progress = (snapshot.bytesTransferred / snapshot.totalBytes) * 100;
                    statusElement.textContent = `📤 Subiendo: ${Math.round(progress)}%`;
                },
                (error) => {
                    console.error('❌ Error al subir audio:', error);
                    alert('Error al subir audio: ' + error.message);
                    statusElement.style.display = 'none';
                },
                async () => {
                    const downloadURL = await window.getDownloadURL(uploadTask.snapshot.ref);
                    console.log('✅ Audio subido, URL:', downloadURL);

                    // Guardar mensaje con audio en Firebase
                    const chatRef = window.ref(window.db, `soporte_cliente/${window.currentUserID}`);
                    const nuevoMensajeRef = window.push(chatRef);
                    
                    await window.set(nuevoMensajeRef, {
                        mensaje: '🎤 Audio',
                        audioURL: downloadURL,
                        tipo: 'audio',
                        remitente: 'cliente',
                        timestamp: Date.now(),
