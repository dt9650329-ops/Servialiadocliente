                        // ────────────────────────────────────────────────────────────
                        // 📊 PASO 3: Calcular tiempo final optimizado
                        // ────────────────────────────────────────────────────────────
                        minRecogida = Math.max(1, tiempoBase + tiempoAdicional); // Mínimo 1 min
                        const minMax = minRecogida + 3; // Margen de ±3 min
                        tiempoEstimadoRecogida = `${minRecogida} – ${minMax} minutos`;
                        tiempoEstimadoEntrega  = `${minRecogida + 10} – ${minMax + 15} minutos`;
                        
                        console.log(`⏱️ TIEMPO CALCULADO: ${tiempoEstimadoRecogida}`);
