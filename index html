        const chatRef = window.ref(window.db, `soporte_cliente/${window.currentUserID}`);
        
        // Detener listener anterior si existe
        if (chatAdminListener) {
            window.off(chatRef, 'value', chatAdminListener);
        }
        
        chatAdminListener = window.onValue(chatRef, (snapshot) => {
            const mensajes = [];
            
            if (snapshot.exists()) {
                snapshot.forEach((child) => {
                    mensajes.push({
                        id: child.key,
                        ...child.val()
                    });
                });
            }
            
            mostrarMensajesAdmin(mensajes);
        });
    }
    
    function mostrarMensajesAdmin(mensajes) {
        const container = document.getElementById('chat-messages-container');
        
        if (mensajes.length === 0) {
            container.innerHTML = `
                <div style="text-align: center; color: #888; padding: 20px;">
                    <p>👋 Hola, estamos aquí para ayudarte con tus pedidos</p>
                    <p style="font-size: 12px;">Los mensajes se envían directamente al administrador</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = '';
        
        mensajes.forEach(msg => {
            const div = document.createElement('div');
            div.className = `chat-message ${msg.remitente || 'cliente'}`;
            
            const fecha = new Date(msg.timestamp);
            const tiempo = fecha.toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit' });
            
            let contenido = '';
            
            // 🆕 Renderizar según tipo de mensaje
            if (msg.tipo === 'imagen' && msg.imagenURL) {
                // Mensaje con imagen
                contenido = `
                    <div style="margin-bottom: 5px;">
                        <img src="${msg.imagenURL}" alt="Imagen" style="max-width: 200px; max-height: 200px; border-radius: 8px; cursor: pointer;" onclick="window.open('${msg.imagenURL}', '_blank')">
                    </div>
                    ${msg.mensaje ? `<div>${msg.mensaje}</div>` : ''}
                `;
            } else if (msg.tipo === 'audio' && msg.audioURL) {
                // Mensaje con audio
                contenido = `
                    <div style="margin-bottom: 5px;">
                        <audio controls style="max-width: 200px;">
                            <source src="${msg.audioURL}" type="audio/webm">
                            Tu navegador no soporta el elemento de audio.
                        </audio>
                    </div>
                    ${msg.mensaje ? `<div>${msg.mensaje}</div>` : ''}
                `;
            } else {
                // Mensaje de texto normal
                contenido = `<div>${msg.mensaje || msg.texto || ''}</div>`;
            }
            
            div.innerHTML = `
                ${contenido}
                <div class="chat-message-time">${tiempo}</div>
            `;
            
            container.appendChild(div);
        });
        
        // Auto-scroll al final
        container.scrollTop = container.scrollHeight;
    }
    
    window.enviarMensajeAdmin = async function() {
        const input = document.getElementById('chat-input');
        const mensaje = input.value.trim();
        
        if (!mensaje) return;
        
        if (!window.currentUserID || !window.db) {
