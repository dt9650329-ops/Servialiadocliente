  // Agregar producto al carrito
  window.agregarAlCarrito = async function(productoId, rutaProducto = 'productos') {
    try {
      const rutaCompleta = `negocios/${tiendaActual.id}/${rutaProducto}/${productoId}`;
      console.log('🛒 Agregando al carrito desde:', rutaCompleta);
      
      // Obtener info del producto
      const productoSnapshot = await get(ref(db, rutaCompleta));
      
      if (!productoSnapshot.exists()) {
        alert('Producto no encontrado');
        return;
      }
      
      const producto = productoSnapshot.val();
      
      // Agregar al carrito
      carritoTienda.push({
        id: productoId,
        nombre: producto.nombre,
        descripcion: producto.descripcion || '',
        precio: producto.precio || 0,
        opciones: producto.opciones || null,
        tipoMenu: producto.tipoMenu || null
      });
      
      actualizarCarritoUI();
      
      // Feedback visual
      const btn = event.target;
      const textoOriginal = btn.textContent;
      btn.textContent = '✅ Agregado';
      btn.style.background = '#28a745';
      setTimeout(() => {
        btn.textContent = textoOriginal;
        btn.style.background = '';
      }, 1000);
      
    } catch (error) {
      console.error('Error al agregar al carrito:', error);
      alert('Error al agregar el producto');
    }
  }

  // Actualizar UI del carrito
  function actualizarCarritoUI() {
    const carritoFlotante = document.getElementById('carrito-flotante');
    const carritoBadge = document.getElementById('carrito-badge');
    
    if (carritoFlotante && carritoBadge) {
      if (carritoTienda.length > 0) {
        carritoFlotante.style.display = 'flex';
        carritoBadge.textContent = carritoTienda.length;
      } else {
        carritoFlotante.style.display = 'none';
      }
    }
    
    // Actualizar lista de items
    const carritoItems = document.getElementById('carrito-items');
    if (carritoItems) {
      if (carritoTienda.length === 0) {
        carritoItems.innerHTML = `
          <div class="carrito-vacio">
            <div class="carrito-vacio-icono">🛒</div>
            <p>Tu carrito está vacío</p>
          </div>
        `;
      } else {
        carritoItems.innerHTML = '';
        carritoTienda.forEach((item, index) => {
          const itemDiv = document.createElement('div');
          itemDiv.className = 'carrito-item';
          
          let descripcionHTML = item.descripcion;
          if (item.opciones) {
            descripcionHTML = Object.values(item.opciones).join(', ');
          }
          
          itemDiv.innerHTML = `
            <div class="carrito-item-info">
              <div class="carrito-item-nombre">${item.nombre}</div>
              <div class="carrito-item-descripcion">${descripcionHTML}</div>
            </div>
            <div class="carrito-item-precio">$${parseInt(item.precio).toLocaleString('es-ES')}</div>
            <button class="btn-eliminar-item" onclick="eliminarDelCarrito(${index})">🗑️</button>
          `;
          
          carritoItems.appendChild(itemDiv);
        });
      }
      
      // Actualizar total
      const total = carritoTienda.reduce((sum, item) => sum + (item.precio || 0), 0);
      const totalMonto = document.getElementById('carrito-total-monto');
      if (totalMonto) {
        totalMonto.textContent = `$${parseInt(total).toLocaleString('es-ES')}`;
      }
    }
  }

