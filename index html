    window.enviarImagenAdmin = async function(event) {
        const file = event.target.files[0];
        if (!file) return;

        if (!window.currentUserID || !window.storage) {
            alert('Error: No hay sesión activa o Firebase Storage no está disponible');
            return;
        }

        console.log('📤 Subiendo imagen al chat con admin...');
        const statusElement = document.getElementById('admin-file-upload-status');
        statusElement.style.display = 'block';
        statusElement.textContent = '📤 Subiendo imagen...';

        try {
            const timestamp = Date.now();
            const fileName = `admin_chat_${window.currentUserID}_${timestamp}_${file.name}`;
            const fileRef = window.storageRef(window.storage, `chats_admin/${fileName}`);
            
            const uploadTask = window.uploadBytesResumable(fileRef, file);

            uploadTask.on('state_changed',
                (snapshot) => {
                    const progress = (snapshot.bytesTransferred / snapshot.totalBytes) * 100;
                    statusElement.textContent = `📤 Subiendo: ${Math.round(progress)}%`;
                },
                (error) => {
                    console.error('❌ Error al subir imagen:', error);
                    alert('Error al subir imagen: ' + error.message);
                    statusElement.style.display = 'none';
                },
                async () => {
                    const downloadURL = await window.getDownloadURL(uploadTask.snapshot.ref);
                    console.log('✅ Imagen subida, URL:', downloadURL);

                    // Guardar mensaje con imagen en Firebase
                    const chatRef = window.ref(window.db, `soporte_cliente/${window.currentUserID}`);
                    const nuevoMensajeRef = window.push(chatRef);
                    
                    await window.set(nuevoMensajeRef, {
                        mensaje: '',
                        imagenURL: downloadURL,
                        tipo: 'imagen',
                        remitente: 'cliente',
                        timestamp: Date.now(),
                        leido: false,
                        clienteNombre: window.currentUserNombre || 'Cliente',
                        clienteEmail: window.currentUserEmail || ''
                    });

                    statusElement.textContent = '✅ Imagen enviada';
                    setTimeout(() => {
                        statusElement.style.display = 'none';
                    }, 2000);

                    event.target.value = '';
                }
            );
        } catch (error) {
            console.error('❌ Error al procesar imagen:', error);
            alert('Error al enviar imagen: ' + error.message);
            statusElement.style.display = 'none';
        }
    }

