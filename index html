    function formatTimestamp(timestamp) {
        if (!timestamp) return "";
        let date;
        try {
            date = new Date(timestamp);
            if (isNaN(date.getTime()) || date.getTime() > Date.now() + 3600000) { 
                date = new Date(Date.now());
            }
        } catch (e) {
            date = new Date(Date.now());
        }
        const options = { 
            hour: '2-digit', minute: '2-digit',
            hour12: true
        };
        return date.toLocaleString('es-ES', options);
