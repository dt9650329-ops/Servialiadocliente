      }
      const data = snap.val();
      const deFirebase = Object.values(data)
        .filter(b => b.activo !== false)
        .map(b => ({
          n: b.nombre,
          z: b.zona || 'centro',
          c: b.nombreComuna || b.comuna || ''
        }));
      if (deFirebase.length > 0) {
        // Combinar Firebase + locales sin duplicados
        const nombres = new Set(deFirebase.map(b => b.n.toLowerCase()));
        const soloLocales = BARRIOS_LOCAL_FMT.filter(b => !nombres.has(b.n.toLowerCase()));
        BARRIOS_ARMENIA = [...deFirebase, ...soloLocales]
