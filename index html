        // Prioridad 2: Geocodificación por nombre de barrio (Firebase → diccionario → Nominatim)
        } else if (pedido.barrioEntrega) {
            const coords = await _geocodificarBarrioCliente(pedido.barrioEntrega);
            if (coords) {
                lat = coords.lat;
                lng = coords.lng;
                popupText = `🏠 Barrio de Entrega<br><small>${pedido.barrioEntrega}</small>`;
            }
