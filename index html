    // 📷 FUNCIÓN OCR: Leer foto de dirección con IA y autocompletar campos
    // ═══════════════════════════════════════════════════════════════════
    window.procesarFotoDireccion = async function(input) {
        if (!input.files || !input.files[0]) return;
        const file = input.files[0];

        const loading = document.getElementById('ocr-loading');
        const preview = document.getElementById('ocr-preview');
        const imgEl   = document.getElementById('ocr-img-preview');
        const status  = document.getElementById('ocr-status');

        // Mostrar preview de la imagen
        const reader = new FileReader();
        reader.onload = async function(e) {
            const base64Full = e.target.result; // data:image/jpeg;base64,...
            const base64Data = base64Full.split(',')[1];
            const mimeType   = file.type || 'image/jpeg';

            // Mostrar preview
            imgEl.src = base64Full;
            preview.style.display = 'block';
            loading.style.display = 'block';
            status.style.display  = 'none';

            // Guardar imagen para el pedido (para mostrarla al repartidor)
            window._fotoDestinatarioBase64 = base64Full;

            try {
                // Llamar al proxy de IA (mismo endpoint que el chatbot)
                const response = await fetch('/api/ai-chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        system: `Eres un extractor de datos para domicilios. El usuario te envía una imagen que puede ser una captura de WhatsApp, una nota escrita o cualquier imagen con datos de un destinatario.
Tu única tarea es encontrar estos campos:
1. Nombre completo del destinatario
2. Dirección de entrega (calle, carrera, número, conjunto, etc.)
3. Número de teléfono (solo dígitos, sin espacios ni guiones)
4. Barrio o sector de entrega

Responde SOLO con este JSON exacto, sin markdown, sin explicaciones, sin texto adicional:
{"nombre":"...","direccion":"...","telefono":"...","barrio":"..."}
Si no encuentras un campo déjalo como "".
Ignora saludos, conversaciones, emojis y cualquier información que no sean datos del destinatario.`,
                        messages: [{
                            role: 'user',
                            content: [
                                { type: 'image', source: { type: 'base64', media_type: mimeType, data: base64Data } },
                                { type: 'text',  text: 'Extrae nombre, dirección, teléfono y barrio del destinatario de esta imagen. Devuelve SOLO el JSON.' }
                            ]
                        }],
                        max_tokens: 300
                    })
                });

                const data = await response.json();
                const rawText = (data.content || []).map(b => b.text || '').join('').trim();

                // Parsear JSON de la respuesta
                const cleaned = rawText.replace(/```json|```/g, '').trim();
                const parsed  = JSON.parse(cleaned);

                // Autocompletar campos
                if (parsed.nombre    && document.getElementById('domi-nombre-recibe'))
                    document.getElementById('domi-nombre-recibe').value = parsed.nombre;
                if (parsed.direccion && document.getElementById('domi-dir-entrega'))
                    document.getElementById('domi-dir-entrega').value = parsed.direccion;
                if (parsed.telefono  && document.getElementById('domi-tel-recibe'))
                    document.getElementById('domi-tel-recibe').value = parsed.telefono;
                if (parsed.barrio    && document.getElementById('search-barrio-entrega'))
                    document.getElementById('search-barrio-entrega').value = parsed.barrio;

                loading.style.display = 'none';
                status.style.display  = 'block';
                status.innerHTML = `✅ <strong>Datos detectados:</strong><br>
                  👤 ${parsed.nombre || '—'}<br>
                  📍 ${parsed.direccion || '—'}<br>
                  📞 ${parsed.telefono || '—'}<br>
                  🏘️ ${parsed.barrio || '—'}<br>
                  <span style="color:#aaa; font-size:11px;">Revisa y corrige si es necesario ↑</span>`;

            } catch (err) {
                loading.style.display = 'none';
                status.style.display  = 'block';
                status.innerHTML = '⚠️ No se pudo leer la imagen. Verifica que la foto sea legible e intenta de nuevo.';
                status.style.color = '#e74c3c';
                console.error('OCR error:', err);
            }
        };
        reader.readAsDataURL(file);
    };

