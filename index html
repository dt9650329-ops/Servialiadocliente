    window.buscarPedidoPorCorreo = async function() {
        const email = document.getElementById('tracking-email-input').value.trim();
        const statusDiv = document.getElementById('tracking-status-message');
        const resultDiv = document.getElementById('tracking-result');
        const mapContainer = document.getElementById('map-container');
        const mapLegend = document.getElementById('map-legend');
        const mapInfo = document.getElementById('map-info');
        
        if (!email) {
            statusDiv.textContent = '⚠️ Por favor, ingresa un correo electrónico.';
            statusDiv.style.color = '#FFD700';
            return;
        }

        if (!window.db || !window.ref || !window.get) {
            statusDiv.textContent = '❌ Error: Firebase no está inicializado.';
            statusDiv.style.color = '#dc3545';
            return;
        }

        statusDiv.textContent = '🔍 Buscando tu pedido...';
        statusDiv.style.color = '#FFD700';
        resultDiv.style.display = 'none';
        resultDiv.innerHTML = '';
        mapContainer.style.display = 'none';
        mapLegend.style.display = 'none';
        mapInfo.style.display = 'none';
        
        detenerSeguimientoUbicacion();
        limpiarMarcadorEntrega();
        mapaYaAjustado = false; // Permitir reajuste al iniciar nuevo seguimiento

        try {
            const usuariosRef = window.ref(window.db, 'usuarios');
            const usuariosSnapshot = await window.get(usuariosRef);
            
            let userUID = null;
            let userName = 'Cliente';
            
            if (usuariosSnapshot.exists()) {
                usuariosSnapshot.forEach((childSnapshot) => {
                    const userData = childSnapshot.val();
                    if (userData.correo && userData.correo.toLowerCase() === email.toLowerCase()) {
                        userUID = userData.uid;
                        userName = userData.nombre || 'Cliente';
                    }
                });
            }

            if (!userUID) {
                statusDiv.textContent = '❌ No se encontró ningún usuario con ese correo.';
                statusDiv.style.color = '#dc3545';
                return;
            }

            const clienteID = `cliente_auth_${userUID}`;

            const pedidosHistorialRef = window.ref(window.db, 'pedidos_historial');
            const historialSnapshot = await window.get(pedidosHistorialRef);
            
            let pedidosEncontrados = [];
            
            if (historialSnapshot.exists()) {
                historialSnapshot.forEach((childSnapshot) => {
                    const pedido = childSnapshot.val();
                    if (pedido.clienteIdAsignado === clienteID) {
                        pedidosEncontrados.push({
                            id: childSnapshot.key,
                            ...pedido
                        });
                    }
                });
            }

            pedidosEncontrados.sort((a, b) => {
                // ✅ FIX: Priorizar pedidos activos/pendientes sobre completados/cancelados
                const estadosActivos = ['pendiente', 'aceptado', 'esperando', 'esperando pedido', 'en camino', 'sin_repartidor'];
                const aActivo = estadosActivos.includes((a.estado || '').toLowerCase());
                const bActivo = estadosActivos.includes((b.estado || '').toLowerCase());

                if (aActivo && !bActivo) return -1; // a va primero
                if (!aActivo && bActivo) return 1;  // b va primero

                // Si ambos tienen el mismo tipo de estado, el más reciente primero
                const timeA = a.timestampCreacion || a.timestampAsignacion || 0;
                const timeB = b.timestampCreacion || b.timestampAsignacion || 0;
                return timeB - timeA;
            });

            if (pedidosEncontrados.length === 0) {
                statusDiv.textContent = '🔭 No se encontraron pedidos asociados a este correo.';
                statusDiv.style.color = '#FFD700';
                return;
            }

            const pedidoReciente = pedidosEncontrados[0];
            await mostrarDetallePedido(pedidoReciente, userName, pedidosEncontrados.length);
            
            statusDiv.textContent = '';

        } catch (error) {
            console.error('❌ Error al buscar pedido:', error);
            statusDiv.textContent = `❌ Error al buscar: ${error.message}`;
            statusDiv.style.color = '#dc3545';
        }
    }
    
