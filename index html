    // Calcular precio según zonas seleccionadas
    window.calcularPrecioDomi = async function() {
        const zonaRecogida = document.getElementById('domi-zona-recogida').value;
        const zonaEntrega  = document.getElementById('domi-zona-entrega').value;
        const tamano       = document.getElementById('domi-tamano').value;
        const precioBox    = document.getElementById('domi-precio-box');
        const precioValor  = document.getElementById('domi-precio-valor');
        const precioRazon  = document.getElementById('domi-precio-razon');
        const tamanoNota   = document.getElementById('domi-tamano-nota');

        // Actualizar nota de tamaño
        if (tamano === 'grande') {
            tamanoNota.textContent = '⚠️ Se cobra $1.000 extra por paquete grande.';
            tamanoNota.style.display = 'block';
        } else if (tamano === 'muy_grande') {
            tamanoNota.textContent = '⚠️ Se cobra $2.000 extra por paquete muy grande. El repartidor podrá reconfirmar si es necesario.';
            tamanoNota.style.display = 'block';
        } else {
            tamanoNota.style.display = 'none';
        }

        const municipioIdCalc = document.getElementById('domi-municipio-id')?.value || '';
        const esFueraCalc = zonaEntrega === 'fuera' || municipioIdCalc !== '';
        if (!zonaRecogida || (!zonaEntrega && !esFueraCalc)) {
            precioBox.style.display = 'none';
            return;
        }

        let precio = 5000;
        let razon  = 'Misma zona';

        // ── TARIFAS FUERA DE ARMENIA ──────────────────────────
        const municipioId = document.getElementById('domi-municipio-id')?.value || '';
        if (municipioId) {
            // Tabla de precios por municipio según zona de recogida
            const tarifasMunicipios = {
                // municipio: { sur, centro, norte, oriente, occidente }
                calarca:       { sur:12000, centro:12000, norte:12000, oriente:12000, occidente:12000 },
                circasia:      { sur:15000, centro:13000, norte:12000, oriente:14000, occidente:15000 },
                montenegro:    { sur:15000, centro:15000, norte:17000, oriente:16000, occidente:14000 },
                tebaida:       { sur:15000, centro:15000, norte:17000, oriente:16000, occidente:15000 },
                puerto_tapao:  { sur:16000, centro:16000, norte:18000, oriente:17000, occidente:15000 },
                salento:       { sur:20000, centro:18000, norte:16000, oriente:18000, occidente:20000 },
                quimbaya:      { sur:22000, centro:20000, norte:18000, oriente:21000, occidente:22000 },
                filandia:      { sur:18000, centro:16000, norte:14000, oriente:16000, occidente:18000 },
                buenavista:    { sur:25000, centro:23000, norte:22000, oriente:24000, occidente:25000 },
                pijao:         { sur:35000, centro:33000, norte:32000, oriente:34000, occidente:35000 },
                genova:        { sur:40000, centro:38000, norte:37000, oriente:39000, occidente:40000 },
                cordoba:       { sur:30000, centro:28000, norte:27000, oriente:29000, occidente:30000 },
            };

            // Vías por km: precio base + recargo por km
            const tarifasVia = {
                via_tebaida:   { base:5000, porKm:800, origenSurCentro:0, origenNorte:2000 },
                via_montenegro:{ base:5000, porKm:800, origenSurCentro:0, origenNorte:2000 },
                via_calarca:   { base:4000, porKm:700, origenSurCentro:0, origenNorte:0    },
                via_circasia:     { base:4000, porKm:700, origenSurCentro:0, origenNorte:0    },
                via_puerto_tapao: { base:5000, porKm:800, origenSurCentro:0, origenNorte:2000 },
            };

            const nombresMunicipios = {
                calarca:'Calarcá', circasia:'Circasia', montenegro:'Montenegro',
                tebaida:'La Tebaida', puerto_tapao:'Puerto Tapao', salento:'Salento',
                quimbaya:'Quimbaya', filandia:'Filandia', buenavista:'Buenavista',
                pijao:'Pijao', genova:'Génova', cordoba:'Córdoba',
                via_tebaida:'Vía Armenia-Tebaida', via_montenegro:'Vía Armenia-Montenegro',
                via_calarca:'Vía Armenia-Calarcá', via_circasia:'Vía Armenia-Circasia',
                vereda_otro:'Vereda / Finca'
            };

            const zona = zonaRecogida || 'centro';

            if (tarifasMunicipios[municipioId]) {
                const t = tarifasMunicipios[municipioId];
                precio = t[zona] || t.centro;
                razon  = `🌄 Armenia (${zona}) → ${nombresMunicipios[municipioId]}`;

            } else if (tarifasVia[municipioId]) {
                const km = parseInt(document.getElementById('domi-km-via')?.value) || 0;
                const t = tarifasVia[municipioId];
                const recargo = zona === 'norte' ? t.origenNorte : t.origenSurCentro;
                precio = t.base + (km * t.porKm) + recargo;
                razon  = `🌄 ${nombresMunicipios[municipioId]} km ${km} · $${t.base.toLocaleString('es-CO')} base + ${km}km×$${t.porKm}`;
                if (recargo > 0) razon += ` + $${recargo.toLocaleString('es-CO')} recargo zona`;

            } else if (municipioId === 'vereda_otro') {
                precio = 0;
                razon  = '⚠️ El admin confirmará el precio por este destino';
                precioValor.textContent = 'A confirmar';
                precioRazon.textContent = razon;
                precioBox.style.display = 'block';
                const extraVol = tamano === 'grande' ? 1000 : tamano === 'muy_grande' ? 2000 : 0;
                if (extraVol > 0) precioRazon.textContent += ` + extra volumen $${extraVol.toLocaleString('es-CO')}`;
                return;
            }

        } else {
            // ── TARIFAS DENTRO DE ARMENIA — por distancia real de ruta ──────────
            // Escala:
            //   ≤ 1.0 km  → $3.000
            //   ≤ 2.1 km  → $4.000
            //   ≤ 4.8 km  → $5.000
            //   ≤ 6.0 km  → $6.000
            //   ≤ 8.5 km  → $7.000
            //   > 8.5 km  → $8.000

            // ── Verificar si es día bomba activo (solo martes=2, en franja horaria) ──
            const hoy = new Date().getDay();
            const horaMin = new Date().getHours() * 60 + new Date().getMinutes();
            const enFranjaBomba = (horaMin >= 480 && horaMin < 660)
                               || (horaMin >= 840 && horaMin < 1080)
                               || (horaMin >= 1200 && horaMin < 1320);
            const esDiaBomba = (hoy === 2) && enFranjaBomba && (window._clienteDiaBombaActivo === true);

            function _precioSegunKm(km) {
                if (km <= 1.0) return 3000;
                if (km <= 2.1) return 4000;
                if (km <= 4.8) return 5000;
                if (km <= 6.0) return 6000;
                if (km <= 8.5) return 7000;
                return 8000;
            }

            const brRec = (document.getElementById('domi-barrio-recogida')?.value || '').trim();
            const brEnt = (document.getElementById('domi-barrio-entrega')?.value || '').trim();

            // Mostrar indicador mientras se calcula
            precioValor.textContent = '...';
            precioRazon.textContent = '📡 Calculando distancia...';
            precioBox.style.display = 'block';

            // Geocodificar ambos barrios en paralelo (Firebase → local → Nominatim)
            const [coordsRec, coordsEnt] = await Promise.all([
                _geocodificarBarrioCliente(brRec || zonaRecogida),
                _geocodificarBarrioCliente(brEnt || zonaEntrega)
            ]);

            if (coordsRec && coordsEnt) {
                let kmRuta = null;
                // Distancia real por carretera via OSRM
                try {
                    const osrmUrl = `https://router.project-osrm.org/route/v1/driving/`
                        + `${coordsRec.lng},${coordsRec.lat};${coordsEnt.lng},${coordsEnt.lat}`
                        + `?overview=false`;
                    const resp = await fetch(osrmUrl);
                    const data = await resp.json();
                    if (data.routes && data.routes[0]) {
                        kmRuta = data.routes[0].distance / 1000;
                    }
                } catch(e) {
                    console.warn('[PRECIO] OSRM no disponible, usando Haversine:', e);
                }

                // Fallback: línea recta (Haversine) si OSRM falla
                if (!kmRuta) {
                    const R = 6371;
                    const dLat = (coordsEnt.lat - coordsRec.lat) * Math.PI / 180;
                    const dLng = (coordsEnt.lng - coordsRec.lng) * Math.PI / 180;
                    const a = Math.sin(dLat/2)**2 + Math.cos(coordsRec.lat * Math.PI/180)
                            * Math.cos(coordsEnt.lat * Math.PI/180) * Math.sin(dLng/2)**2;
                    kmRuta = R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                    console.warn('[PRECIO] Usando Haversine:', kmRuta.toFixed(2), 'km');
                }

                const kmDisplay = Math.round(kmRuta * 10) / 10;
                precio = _precioSegunKm(kmRuta);
                razon  = `📏 ${kmDisplay} km · ${brRec || zonaRecogida} → ${brEnt || zonaEntrega}`;
            } else {
                // Sin coordenadas: fallback conservador por zonas
                const zonas  = { sur:0, centro:1, norte:2, oriente:1, occidente:1 };
                const nombres= { sur:'Sur', centro:'Centro', norte:'Norte', oriente:'Oriente', occidente:'Occidente' };
                const diff   = Math.abs((zonas[zonaRecogida]||0) - (zonas[zonaEntrega]||0));
                if (zonaRecogida === zonaEntrega) {
                    precio = 4000; razon = `Misma zona (${nombres[zonaRecogida]||zonaRecogida})`;
                } else if (diff <= 1) {
                    precio = 5000; razon = `Zonas contiguas`;
                } else {
                    precio = 7000; razon = `Zonas lejanas`;
                }
            }

            if (esDiaBomba) {
                precio = Math.round(precio * 0.80);
                razon = `💥 Día Bomba −20% · ` + razon;
            }
        }

        // Extra por volumen
        const extraVolumen = tamano === 'grande' ? 1000 : tamano === 'muy_grande' ? 2000 : 0;
        if (extraVolumen > 0) {
            precio += extraVolumen;
            razon += ` + extra volumen`;
        }

        precioValor.textContent = `$${precio.toLocaleString('es-CO')}`;
        precioRazon.textContent  = razon;
        precioBox.style.display  = 'block';

        // Calcular tiempo real del repartidor disponible
        await _actualizarTiempoEstimadoFormulario();
    };

    // ═══════════════════════════════════════════════════════════════════
    // 📍 FUNCIÓN GPS: Calcular distancia desde Armenia y precio automático
    //    Tarifa fuera de Armenia: $10.000 mínimo + $1.000 por km
    // ═══════════════════════════════════════════════════════════════════
    window.calcularDistanciaGPS = function(tipo) {
        const resultDiv = document.getElementById(`gps-${tipo}-result`);
        const btn = resultDiv ? resultDiv.previousElementSibling : null;

        if (!navigator.geolocation) {
            alert('❌ Tu dispositivo no soporta GPS');
            return;
        }

        if (resultDiv) {
            resultDiv.style.display = 'block';
            resultDiv.innerHTML = '📡 Obteniendo tu ubicación GPS...';
        }

        navigator.geolocation.getCurrentPosition(
            function(position) {
                const lat = position.coords.latitude;
                const lng = position.coords.longitude;

                // Centro de Armenia, Quindío, Colombia
                const ARMENIA_LAT = 4.5339;
                const ARMENIA_LNG = -75.6811;

                // Fórmula Haversine para calcular distancia en km
                function haversine(lat1, lon1, lat2, lon2) {
                    const R = 6371;
                    const dLat = (lat2 - lat1) * Math.PI / 180;
                    const dLon = (lon2 - lon1) * Math.PI / 180;
                    const a = Math.sin(dLat/2)*Math.sin(dLat/2) +
                              Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*
                              Math.sin(dLon/2)*Math.sin(dLon/2);
                    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
                    return R * c;
                }

                const distanciaKm = haversine(ARMENIA_LAT, ARMENIA_LNG, lat, lng);
                const distanciaRedondeada = Math.round(distanciaKm * 10) / 10;

                // Tarifa: $10.000 base + $1.000 por km (mínimo $10.000)
                const precioGPS = Math.max(10000, Math.round(10000 + (distanciaKm * 1000)));
                const coordsText = `${lat.toFixed(5)}, ${lng.toFixed(5)}`;
                const mapsUrl = `https://www.google.com/maps?q=${lat},${lng}`;

                // Llenar el campo de dirección con las coordenadas GPS
                if (tipo === 'destino') {
                    const dirInput = document.getElementById('domi-dir-entrega');
                    if (dirInput && !dirInput.value) {
                        dirInput.value = `📍 GPS: ${coordsText}`;
                    }
                    // Guardar precio GPS para el pedido
                    window._gpsPrecioDestino = precioGPS;
                    window._gpsDistanciaDestino = distanciaRedondeada;
                    window._gpsCoordsDestino = { lat, lng };

                    // Mostrar precio en el box de precio
                    const precioBox   = document.getElementById('domi-precio-box');
                    const precioValor = document.getElementById('domi-precio-valor');
                    const precioRazon = document.getElementById('domi-precio-razon');
                    if (precioBox && precioValor && precioRazon) {
                        precioBox.style.display = 'block';
                        precioValor.textContent = `$${precioGPS.toLocaleString('es-CO')}`;
                        precioRazon.textContent  = `📍 GPS: ${distanciaRedondeada} km desde Armenia · $10.000 base + $1.000/km`;
                    }
                } else {
                    const dirInput = document.getElementById('domi-dir-recogida');
                    if (dirInput && !dirInput.value) {
                        dirInput.value = `📍 GPS: ${coordsText}`;
                    }
                    window._gpsPrecioRecogida = precioGPS;
                    window._gpsDistanciaRecogida = distanciaRedondeada;
                    window._gpsCoordsRecogida = { lat, lng };
                }

                if (resultDiv) {
                    resultDiv.style.display = 'block';
                    resultDiv.innerHTML = `
                      ✅ <strong>Ubicación detectada</strong><br>
                      📏 Distancia desde Armenia: <strong>${distanciaRedondeada} km</strong><br>
                      💰 Precio estimado del servicio: <strong>$${precioGPS.toLocaleString('es-CO')}</strong><br>
                      <span style="font-size:11px; color:#aaa;">($10.000 mínimo + $1.000/km)</span><br>
                      <a href="${mapsUrl}" target="_blank" style="color:#4A9EFF; font-size:11px;">📍 Ver en Google Maps</a>
                    `;
                }
            },
            function(error) {
                const msgs = {
                    1: 'Permiso de ubicación denegado. Ve al menú ☰ → Permisos → Activar Ubicación GPS.',
                    2: 'No se pudo obtener tu ubicación. Intenta en exteriores.',
                    3: 'Tiempo de espera agotado. Intenta de nuevo.'
                };
                if (resultDiv) {
                    resultDiv.style.display = 'block';
                    resultDiv.innerHTML = `❌ ${msgs[error.code] || 'Error de GPS'}`;
                    resultDiv.style.color = '#e74c3c';
                }
            },
            { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
        );
    };

