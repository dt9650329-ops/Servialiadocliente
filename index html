    // ── TOGGLE PANEL ──────────────────────────────────────────
    window.toggleAIChat = function () {
        aiOpen = !aiOpen;
        document.getElementById('ai-chat-panel').classList.toggle('open', aiOpen);
        document.getElementById('ai-notif-dot').style.display = 'none';

        if (aiOpen && aiHistory.length === 0) {
            addBotMessage('¡Hola! 👋 Soy **ServiBot**, tu asistente de *Servi Aliados*.\n\n¿En qué te puedo ayudar? Consulta precios, zonas, tiempos o el estado de tu pedido. 🛵');
        }
        if (aiOpen) {
            setTimeout(() => document.getElementById('ai-chat-input').focus(), 200);
        }
    };

    // ── BOTONES RÁPIDOS ───────────────────────────────────────
    window.sendQuick = function (text) {
        document.getElementById('ai-chat-input').value = text;
        sendAIMessage();
    };

    // ── ENVIAR MENSAJE ────────────────────────────────────────
    window.sendAIMessage = function () {
        if (aiWorking) return;
        const input = document.getElementById('ai-chat-input');
        const text  = input.value.trim();
        if (!text) return;
        input.value = '';

        addUserMessage(text);
        hideQuickBtns();
        aiWorking = true;

        aiHistory.push({ role: 'user', content: text });

        // Simular pequeño delay para que se sienta natural
        const typingId = addBotMessage('✍️ Escribiendo...', true);
        setTimeout(function () {
            const respuesta = obtenerRespuesta(text);

            // Detectar si el usuario tiene queja/sugerencia y guardarla en Firebase
            const msgLower = text.toLowerCase();
            if (/queja|reclamo|sugerencia|falla|error|problema|mal servicio|mejora/.test(msgLower)) {
                guardarSugerenciaIA('💬 Mensaje del cliente: ' + text.substring(0, 250));
            }

            aiHistory.push({ role: 'assistant', content: respuesta });
            updateBotMessage(typingId, respuesta);
            aiWorking = false;
        }, 600);
    };

    // ── GUARDAR SUGERENCIA EN FIREBASE ────────────────────────
    async function guardarSugerenciaIA(resumen) {
        try {
            if (!window.db || !window.ref || !window.push || !window.set) return;
            const newRef = window.push(window.ref(window.db, 'sugerencias_ia'));
            await window.set(newRef, {
                resumen      : resumen,
                clienteUID   : window.currentUserID   || 'anonimo',
                clienteNombre: window.currentUserNombre || 'Anónimo',
                timestamp    : Date.now(),
                fecha        : new Date().toISOString(),
                revisado     : false   // el admin marca esto como true al revisar
            });
            console.log('💡 Sugerencia IA guardada en Firebase:', resumen);
        } catch (e) {
            console.warn('⚠️ No se pudo guardar sugerencia:', e);
        }
    }

    // ── UI HELPERS ────────────────────────────────────────────
    function addUserMessage(text) {
        const box = document.getElementById('ai-messages');
        const div = document.createElement('div');
        div.className   = 'ai-msg user';
        div.textContent = text;
        box.appendChild(div);
        box.scrollTop = box.scrollHeight;
    }

    function addBotMessage(text, isTyping = false) {
        const id  = 'aimsg-' + (++msgCounter);
        const box = document.getElementById('ai-messages');
        const div = document.createElement('div');
        div.id        = id;
        div.className = 'ai-msg bot' + (isTyping ? ' typing' : '');
        div.innerHTML = formatBotText(text);
        box.appendChild(div);
        box.scrollTop = box.scrollHeight;
        return id;
    }

    function updateBotMessage(id, text) {
        const el = document.getElementById(id);
        if (!el) return;
        el.classList.remove('typing');
        el.innerHTML = formatBotText(text);
        document.getElementById('ai-messages').scrollTop = 99999;
    }

    function formatBotText(t) {
        return t
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g, '<em>$1</em>')
            .replace(/\n/g, '<br>');
    }

    function hideQuickBtns() {
        const q = document.getElementById('ai-quick-btns');
        if (q) q.style.display = 'none';
    }

    // ── BOTÓN "ENVIAR PREGUNTA A SOPORTE" ────────────────────
    window.abrirSugerenciaIA = function () {
        // Obtener la última pregunta del usuario del historial
        const ultimaConsulta = (aiHistory.slice().reverse().find(m => m.role === 'user') || {}).content
            || 'Consulta sin especificar';
        // Guardar en Firebase > sugerencias_ia para que admin la vea
        guardarSugerenciaIA('❓ Pregunta sin respuesta del bot: ' + ultimaConsulta.substring(0, 250));
        // Redirigir a WhatsApp del encargado
        const msg = encodeURIComponent('Hola, tengo una pregunta que el asistente no pudo responder:\n\n' + ultimaConsulta.substring(0, 200));
        window.open('https://wa.me/3237942133?text=' + msg, '_blank');
    };

})();
</script>

