    window.actualizarNivelPerfil = function() {
        const est = _premiosGetEstado();
        const totalPedidos = est.pedidosAcum || 0;

        // Buscar nivel actual
        let nivelActual = NIVELES[0];
        let nivelSig    = NIVELES[1];
        for (let i = NIVELES.length - 1; i >= 0; i--) {
            if (totalPedidos >= NIVELES[i].min) {
                nivelActual = NIVELES[i];
                nivelSig    = NIVELES[Math.min(i + 1, NIVELES.length - 1)];
                break;
            }
        }

        const esMaxNivel = nivelActual.nivel === NIVELES[NIVELES.length - 1].nivel;
        const pedEnNivel = totalPedidos - nivelActual.min;
        const rangNivel  = nivelActual.max - nivelActual.min;
        const pct        = esMaxNivel ? 100 : Math.min(100, Math.round((pedEnNivel / rangNivel) * 100));
        const faltantes  = esMaxNivel ? 0 : nivelActual.max - totalPedidos;

        const badge      = document.getElementById('perfil-nivel-badge');
