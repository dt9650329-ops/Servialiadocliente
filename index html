                        clienteNombre: window.currentUserNombre || 'Cliente',
                        clienteEmail: window.currentUserEmail || ''
                    });

                    statusElement.textContent = '✅ Audio enviado';
                    setTimeout(() => {
                        statusElement.style.display = 'none';
                    }, 2000);
                }
            );
        } catch (error) {
            console.error('❌ Error al enviar audio:', error);
            alert('Error al enviar audio: ' + error.message);
            statusElement.style.display = 'none';
        }
    }

