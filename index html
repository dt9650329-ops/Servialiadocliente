                                        explicacionRuta = `✅ Recogerá primero ambos pedidos de la zona ${pedido.zonaRecogida}`;
                                    }
                                    continue;
                                }

                                // ═══════════════════════════════════════════════════════════
                                // 🎯 REGLA 3: Si el NUEVO pedido queda EN RUTA hacia la entrega actual
