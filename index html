<!-- ══ GPS UTILITIES — Registro y Servicio ══════════════════════ -->
<script>
// Reverse geocoding compartido (Nominatim, sin API key)
async function reverseGeocode(lat, lon) {
  const res = await fetch(
    `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&accept-language=es`,
    { headers: { 'Accept-Language': 'es' } }
  );
  return await res.json();
}
function construirDireccion(addr) {
  return [
    addr.road || addr.pedestrian || addr.street || '',
    addr.house_number || '',
    addr.suburb || addr.neighbourhood || addr.quarter || '',
    addr.city || addr.town || addr.village || ''
  ].filter(Boolean).join(', ');
}

// ── 1. GPS en formulario de REGISTRO ────────────────────────────
window.usarUbicacionEnRegistro = function() {
  const statusEl = document.getElementById('gps-registro-status');
  const dirInput = document.getElementById('direccionUsuario');
  statusEl.style.display = 'block';
  statusEl.style.color   = '#4A9EFF';
  statusEl.textContent   = '📡 Detectando tu ubicación...';
  if (!navigator.geolocation) {
    statusEl.textContent = '❌ Tu dispositivo no soporta GPS.';
    statusEl.style.color = '#dc3545'; return;
  }
  navigator.geolocation.getCurrentPosition(async (pos) => {
    const { latitude: lat, longitude: lon } = pos.coords;
    statusEl.textContent = '🔍 Obteniendo dirección...';
    try {
      const data = await reverseGeocode(lat, lon);
      const dir  = construirDireccion(data.address || {});
      if (dir) {
        dirInput.value       = dir;
        statusEl.textContent = '✅ Dirección detectada. Revisa y edita si hace falta.';
        statusEl.style.color = '#28a745';
      } else {
        statusEl.textContent = '⚠️ No se obtuvo la dirección. Escríbela manualmente.';
        statusEl.style.color = '#e67e22';
      }
    } catch(e) {
      statusEl.textContent = '❌ Error de red. Escribe tu dirección manualmente.';
      statusEl.style.color = '#dc3545';
    }
  }, (err) => {
    statusEl.textContent = err.code === 1
      ? '❌ Permiso denegado. Escribe tu dirección manualmente.'
      : '❌ No se pudo obtener la ubicación.';
    statusEl.style.color = '#dc3545';
  }, { enableHighAccuracy: true, timeout: 12000 });
};

// ── 2. GPS en Punto A (recogida) del formulario de SERVICIO ─────
window.usarUbicacionEnRecogida = function() {
  const mismatchDiv = document.getElementById('gps-recogida-mismatch');
  const dirInput    = document.getElementById('domi-dir-recogida');
  if (mismatchDiv) mismatchDiv.style.display = 'none';
  if (!navigator.geolocation) { alert('⚠️ Tu dispositivo no soporta GPS.'); return; }
  const btn = event ? event.target : null;
  if (btn) { btn.disabled = true; btn.textContent = '📡 Detectando...'; }
  navigator.geolocation.getCurrentPosition(async (pos) => {
    const { latitude: lat, longitude: lon } = pos.coords;
    try {
      const data = await reverseGeocode(lat, lon);
      const dir  = construirDireccion(data.address || {});
      if (dir) {
        dirInput.value = dir;
        if (btn) btn.textContent = '✅ Ubicación cargada como dirección de recogida';
      } else {
        if (btn) btn.textContent = '⚠️ No se obtuvo la dirección. Escríbela manualmente.';
      }
    } catch(e) {
      if (btn) btn.textContent = '❌ Error de red. Escribe la dirección manualmente.';
    }
    if (btn) btn.disabled = false;
  }, () => {
    alert('❌ No se pudo obtener la ubicación. Escribe la dirección de recogida manualmente.');
    if (btn) { btn.disabled = false; btn.textContent = '📍 Usar mi ubicación actual como dirección de recogida'; }
  }, { enableHighAccuracy: true, timeout: 12000 });
};

// ── 3. VALIDACIÓN GPS vs dirección antes de confirmar pedido ────
window.verificarGPSvsDireccion = async function(dirEscrita, callback) {
  if (!window.clienteUbicacionActual) { callback(); return; }
  const { lat, lng } = window.clienteUbicacionActual;
  try {
    const data     = await reverseGeocode(lat, lng);
    const addr     = data.address || {};
    const barriGPS = (addr.suburb || addr.neighbourhood || addr.quarter || addr.road || '').toLowerCase();
    const dirLower = dirEscrita.toLowerCase();
    // Si tienen palabras en común → sin problema
    if (!barriGPS || dirLower.includes(barriGPS) ||
        barriGPS.split(' ').some(w => w.length > 3 && dirLower.includes(w))) {
      callback(); return;
    }
    // Discrepancia → mostrar aviso
    const mismatchDiv = document.getElementById('gps-recogida-mismatch');
    const dirGPS      = construirDireccion(addr);
    if (mismatchDiv) {
      mismatchDiv.style.display = 'block';
      mismatchDiv.innerHTML = `
